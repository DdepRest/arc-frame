<Window x:Class="MosquitoNetCalculator.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MosquitoNetCalculator.Models"
        Title="Добро пожаловать"
        Width="480" Height="660"
        MinHeight="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Icon="pack://application:,,,/Resources/app_icon.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource Border}" BorderThickness="1"
            CornerRadius="12" Padding="4" Margin="8">
        <Border.Effect>
            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="20" ShadowDepth="2" Opacity="0.12"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border x:Name="TitleBarBorder" Grid.Row="0"
                    Background="{DynamicResource HeaderBg}"
                    CornerRadius="12,12,0,0"
                    Height="32"
                    Padding="14,0,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Добро пожаловать в A.R.C. Frame"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <!-- Theme toggle button -->
                    <Button Grid.Column="1"
                            x:Name="BtnTheme"
                            Width="32" Height="32" Background="Transparent"
                            BorderThickness="0" Cursor="Hand"
                            Padding="0" Margin="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="Сменить тему"
                            Click="BtnTheme_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                    <Grid>
                                        <Border x:Name="HoverOverlay" Background="{DynamicResource Accent}" Opacity="0"/>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="1" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock x:Name="TxtThemeIcon"
                                   Text="&#xE706;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="0"/>
                    </Button>
                    <!-- Close button -->
                    <Button Grid.Column="2"
                            Width="32" Height="32" Background="Transparent"
                            BorderThickness="0" Cursor="Hand"
                            Padding="0" Margin="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="Закрыть"
                            Click="BtnClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                    <Grid>
                                        <Border x:Name="HoverOverlay" Background="{DynamicResource Danger}" Opacity="0"/>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="1" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="0"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content area (Grid: header / list* / preview / button) -->
            <Grid Grid.Row="1" Margin="20,14,20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Выберите своё местоположение"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Это определит нумерацию договоров."
                               FontSize="12"
                               Foreground="{DynamicResource TextMuted}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>
                </StackPanel>

                <!-- Selection list — single source of truth: Models/LocationOptions.All -->
                <ListBox x:Name="OptionsList"
                         Grid.Row="1"
                         ItemsSource="{x:Static models:LocationOptions.All}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource TextPrimary}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Padding="0,0,0,4"
                         SelectionChanged="OptionsList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="FocusVisualStyle" Value="{StaticResource FluentFocusVisual}"/>
                            <!-- Strip the default ListBoxItem chrome (focus rectangle,
                                 hover background, blue selection highlight). Visual
                                 state is fully owned by the DataTemplate's triggers
                                 so the cards stay theme-consistent. -->
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter HorizontalAlignment="Stretch"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="CardBorder"
                                    Background="{DynamicResource SectionBg}"
                                    BorderBrush="{DynamicResource Border}"
                                    BorderThickness="1.5"
                                    CornerRadius="8"
                                    Padding="14,12"
                                    Margin="0,0,0,8"
                                    Cursor="Hand">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Ellipse x:Name="RadioIndicator"
                                             Grid.Column="0" Grid.RowSpan="2"
                                             Width="20" Height="20"
                                             Stroke="{DynamicResource Border}"
                                             StrokeThickness="2"
                                             Margin="0,0,12,0"
                                             VerticalAlignment="Center"
                                             RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <TextBlock Grid.Column="1" Grid.Row="0"
                                               Text="{Binding LocationName}"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Grid.Column="1" Grid.Row="1"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMuted}">
                                        <Run Text="Префикс договора: "/>
                                        <!-- Mode=OneWay is required: Run.Text's default
                                             binding mode is TwoWay in WPF, which would
                                             try to write back into the read-only
                                             LocationOption.Prefix and throw
                                             XamlParseException at template load. -->
                                        <Run Text="{Binding Prefix, Mode=OneWay}"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <!-- Single source of truth for the "selected" appearance.
                                     Triggers on ListBoxItem.IsSelected, so neither XAML
                                     nor code-behind have to track selection state. -->
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                             Value="True">
                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource AccentLight}"/>
                                    <Setter TargetName="RadioIndicator" Property="Fill" Value="{DynamicResource Accent}"/>
                                    <Setter TargetName="RadioIndicator" Property="Stroke" Value="{DynamicResource Accent}"/>
                                    <!-- Scale-pulse the radio dot for satisfying click feedback -->
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="RadioIndicator"
                                                                 Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                 From="1.0" To="1.2"
                                                                 Duration="0:0:0.15"
                                                                 AutoReverse="True">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="RadioIndicator"
                                                                 Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                 From="1.0" To="1.2"
                                                                 Duration="0:0:0.15"
                                                                 AutoReverse="True">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Contract number preview -->
                <Border Grid.Row="2"
                        Background="{DynamicResource QuickBg}"
                        BorderBrush="{DynamicResource SubtleBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,10"
                        Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Номер договора: "
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="PreviewContractNumber"
                                   Text="1-1"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource Accent}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Continue button (always visible at the bottom) -->
                <Button x:Name="BtnContinue"
                        Grid.Row="3"
                        Content="Продолжить"
                        Style="{DynamicResource PrimaryButton}"
                        HorizontalAlignment="Center"
                        MinWidth="180"
                        Margin="0,10,0,0"
                        Padding="16,9"
                        FontSize="14"
                        IsDefault="True"
                        Click="BtnContinue_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
