            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"
                                Padding="{Binding Padding, RelativeSource={RelativeSource TemplatedParent}}" CornerRadius="5"
                                SnapsToDevicePixels="True">
