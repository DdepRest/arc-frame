        </Style>

        <!-- Danger — Fluent red -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Danger}"/>
            <Setter Property="Foreground" Value="{DynamicResource OnDanger}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"
