                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DangerHover}"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>                                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.35" Color="#C42B1C"/>
