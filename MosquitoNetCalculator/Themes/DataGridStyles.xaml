<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- ROW HOVER EASING — shared by all DataGridRow animations   -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <CubicEase x:Key="RowEase" EasingMode="EaseOut"/>
        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- DATA GRID — Windows 11 Fluent Design                    -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource GridLine}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinRowHeight" Value="32"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource RowAlt}"/>
            <Setter Property="RowBackground" Value="{DynamicResource Surface}"/>
            <Setter Property="ColumnHeaderHeight" Value="36"/>
            <Setter Property="Background" Value="{DynamicResource Surface}"/>
            <Setter Property="ScrollViewer.Padding" Value="0"/>
            <!-- Hide scrollbar gutter completely: no layout space reserved,
                 data uses full width. Mouse wheel scrolling still works. -->
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource HeaderBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource HeaderText}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HeaderBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border x:Name="Bd"
                                Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}}"
                                Padding="{Binding Padding, RelativeSource={RelativeSource TemplatedParent}}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HeaderPress}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HeaderPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

                <!--
          OrderRow — animated hover/select style for the OrderGrid in the
          "Расчёт" tab. Subtle ColorAnimation on the row background, no glow,
          no transform. Apply via DataGrid.RowStyle="{StaticResource OrderRow}".

          INVARIANT: the OrderGrid must keep RowBackground="Transparent" (and
          AlternatingRowBackground="Transparent"), because the ColorAnimation
          targets (Background).(SolidColorBrush.Color) and only works when no
          higher-priority brush overrides the row's Background.
        -->
        <Style x:Key="OrderRow" TargetType="DataGridRow">
            <!-- No Background setter here on purpose: WPF auto-freezes every
                 Freezable set via a Style.Setter, so a SolidColorBrush from
                 here would be frozen and the ColorAnimation in the triggers
                 below would crash with "Cannot animate on a freezable".
                 The brush is set per-row in MainWindow.OrderGrid_LoadingRow,
                 which gives a fresh, mutable SolidColorBrush per row instance
                 and beats the style's frozen brush (local value > style).

                 No IsSelected visual at all on purpose: the persistent
                 AccentLight tint was unwanted, AND the WPF default
                 DataGridRow ControlTemplate has its own IsSelected trigger
                 that paints the row with SystemColors.HighlightBrush — in
                 dark theme that resolves to a near-white bar that wipes
                 out the row content. Template triggers beat style triggers
                 in WPF's trigger precedence, so a plain Style.Trigger for
                 IsSelected would NOT override it. The minimal Template
                 below omits the default IsSelected trigger entirely, so
                 the per-row Background brush (animated by the triggers
                 below) is the only thing the user ever sees — selected
                 rows look identical to unselected ones. -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                <Border x:Name="DGR_RowBorder" Background="{TemplateBinding Background}" CornerRadius="4">
                    <DataGridCellsPresenter ItemsPanel="{TemplateBinding ItemsPanel}"/>
                </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Inactive rows stay at 0.45 opacity, just like before. -->
                <DataTrigger Binding="{Binding IsActive}" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </DataTrigger>
                <!--
                  Hover animation is handled in CODE-BEHIND
                  (MainWindow.OrderRow_MouseEnter / _MouseLeave), not here.

                  Why not in XAML: a ColorAnimation's `To` property is a CLR
                  property, not a DependencyProperty, so {StaticResource
                  RowHoverColor} is resolved ONCE at XAML parse time and
                  baked into the animation. ThemeService updates the
                  RowHoverColor Color resource at runtime, but the animation
                  never re-reads it — so after a theme switch, hovering a
                  row animates to whatever the light-theme RowHoverColor was
                  at app startup, producing a "white bar on dark theme" bug.

                  The code-behind handlers read the current resource value
                  at trigger time, so the animation always uses the
                  current theme's hover color. The per-row brush from
                  OrderGrid_LoadingRow is still the mutable target.
                -->
            </Style.Triggers>
        </Style>

        <!--
          OrdersRow — animated hover style for the OrdersList in the
          "Заказы" tab. Same approach as OrderRow (custom Template + code- behind
          Opacity fade), but the per-row brush starts invisible so the
          alternating RowBackground / AlternatingRowBackground from the
          DataGrid shows through when not hovered. Selected and unselected
          rows look identical — the WPF default Template's IsSelected trigger
          (SystemColors.HighlightBrush) is removed, so no "white bar" in
          dark theme.
        -->
        <Style x:Key="OrdersRow" TargetType="DataGridRow">
            <!-- Same frozen-brush rationale as OrderRow: the per-row brush
                 comes from MainWindow.OrdersList_LoadingRow, not from here. -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                <Border x:Name="DGR_RowBorder" Background="{TemplateBinding Background}" CornerRadius="4">
                    <DataGridCellsPresenter ItemsPanel="{TemplateBinding ItemsPanel}"/>
                </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
          PriceRow — animated hover style for the PriceGrid in the
          "Цены" tab. Same approach as OrdersRow: custom Template without
          the WPF default IsSelected trigger (no "white bar" in dark theme),
          code-behind Opacity fade via PriceGrid_LoadingRow / OrderRow_MouseEnter/
          _MouseLeave. The per-row brush starts at Opacity=0 (invisible) so
          the DataGrid's RowBackground / AlternatingRowBackground shows through.
        -->
        <Style x:Key="PriceRow" TargetType="DataGridRow">
            <!-- Same frozen-brush rationale as OrderRow: the per-row brush
                 comes from MainWindow.PriceGrid_LoadingRow, not from here. -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                <Border x:Name="DGR_RowBorder" Background="{TemplateBinding Background}" CornerRadius="4">
                    <DataGridCellsPresenter ItemsPanel="{TemplateBinding ItemsPanel}"/>
                </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Default DataGridRow: plain, no animation. Used by PriceGrid, etc.
             No Background setter — WPF would freeze any Freezable set here.
             The DataGrid's own RowBackground + AlternatingRowBackground are
             what actually paint these rows, so this style is intentionally
             empty. -->
        <Style TargetType="DataGridRow"/>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="0"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                              VerticalAlignment="{Binding VerticalContentAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                              Margin="2,0"
                                              SnapsToDevicePixels="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
</ResourceDictionary>
