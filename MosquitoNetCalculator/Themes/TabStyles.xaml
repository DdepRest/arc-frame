<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- TABS — Windows 11 Fluent NavigationView-style           -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Regular"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <!-- Remove WPF's default focus rectangle: it's blue, thin, and inset from the
                 tab text, which looks like a glitchy outline on hover. -->
            <Setter Property="FocusVisualStyle" Value="{StaticResource FluentFocusVisual}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <!-- Outer Border — no Padding here; the HoverOverlay lives inside
                             the Grid so it stretches to the full cell size (including the
                             margin that was previously the Padding). This makes the hover
                             tint fill the whole tab cell, not just the text area. -->
                        <Border x:Name="OuterBd"
                                Background="Transparent" CornerRadius="4"
                                SnapsToDevicePixels="True"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Grid>
                                <!-- Hover overlay — AccentLight tint for a visible but calm Fluent hover -->
                                <Border x:Name="HoverOverlay" Background="{DynamicResource AccentLight}"
                                        CornerRadius="4" Opacity="0"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                    <StackPanel Margin="18,8" RenderTransformOrigin="0.5,0.5">
                                        <StackPanel.RenderTransform>
                                            <ScaleTransform x:Name="TabScale" ScaleX="1" ScaleY="1"/>
                                        </StackPanel.RenderTransform>
                                        <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center" ContentSource="Header"/>
                                        <!-- Selection underline indicator — grows from center when selected -->
                                        <Border x:Name="Indicator" Width="0" Height="3" Margin="0,4,0,0"
                                                CornerRadius="1.5" Background="{DynamicResource Accent}"
                                                HorizontalAlignment="Center" Opacity="0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                            <Setter Property="Width" Value="24"/>
                                                            <Setter Property="Opacity" Value="1"/>
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                                         From="0" To="24" Duration="0:0:0.25">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="0" To="1" Duration="0:0:0.15">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                                         From="24" To="0" Duration="0:0:0.2">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="1" To="0" Duration="0:0:0.2">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Background tint fades in -->
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <!-- Micro-scale content up 3 % for a tactile feel -->
                                            <DoubleAnimation Storyboard.TargetName="TabScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.03" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="TabScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.03" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Background tint fades out -->
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <!-- Micro-scale content back to normal -->
                                            <DoubleAnimation Storyboard.TargetName="TabScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="TabScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
</ResourceDictionary>
