<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- FLUENT FOCUS VISUAL — Windows 11-style keyboard focus    -->
    <!-- Закруглённая Accent-рамка 2px с отступом −2px (снаружи). -->
    <!-- Используется через FocusVisualStyle="{StaticResource     -->
    <!-- FluentFocusVisual}" на всех интерактивных элементах.     -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Style x:Key="FluentFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle Stroke="{DynamicResource Accent}"
                               StrokeThickness="2"
                               RadiusX="4" RadiusY="4"
                               SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
