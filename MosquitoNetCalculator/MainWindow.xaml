<Window x:Class="MosquitoNetCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MosquitoNetCalculator.Controls"
        Title="A.R.C. Frame"
        Width="1200" Height="760"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Closing="MainWindow_Closing"
        ResizeMode="CanResize"
        Background="Transparent"
        Foreground="{DynamicResource TextPrimary}"
        Icon="pack://application:,,,/Resources/app_icon.ico"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        SnapsToDevicePixels="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- ГОРЯЧИЕ КЛАВИШИ                                          -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Window.InputBindings>
        <!-- Ctrl+S — сохранить заказ -->
        <KeyBinding Key="S" Modifiers="Control" Command="ApplicationCommands.Save"/>
        <!-- Ctrl+1..4 — навигация -->
        <KeyBinding Key="D1" Modifiers="Control" Command="NavigationCommands.BrowseBack"/>
        <KeyBinding Key="D2" Modifiers="Control" Command="NavigationCommands.BrowseForward"/>
        <KeyBinding Key="D3" Modifiers="Control" Command="NavigationCommands.Search"/>
        <KeyBinding Key="D4" Modifiers="Control" Command="NavigationCommands.Favorites"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Save" Executed="BtnSaveOrder_Click"/>
        <CommandBinding Command="NavigationCommands.BrowseBack"  Executed="NavCalculation_Click"/>
        <CommandBinding Command="NavigationCommands.BrowseForward" Executed="NavOrders_Click"/>
        <CommandBinding Command="NavigationCommands.Search"      Executed="NavPrices_Click"/>
        <CommandBinding Command="NavigationCommands.Favorites"   Executed="NavUpdates_Click"/>
    </Window.CommandBindings>

    <Window.Resources>
        <!-- Fade-in / fade-out storyboards for UpdateDownloadBar -->
        <Storyboard x:Key="UpdateBarFadeIn">
            <DoubleAnimation Storyboard.TargetName="UpdateDownloadBar"
                             Storyboard.TargetProperty="Opacity"
                             From="0.0" To="1.0"
                             Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="UpdateBarFadeOut">
            <DoubleAnimation Storyboard.TargetName="UpdateDownloadBar"
                             Storyboard.TargetProperty="Opacity"
                             To="0.0"
                             Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- NavigationView button style (slide-out labels) -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" BorderThickness="0"
                                Height="40">
                            <Grid>
                                <!-- Active indicator pill (left edge) -->
                                <Border x:Name="ActivePill" Width="3" Height="16"
                                        Background="{DynamicResource Accent}"
                                        CornerRadius="1.5"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Margin="0,0,0,0" Opacity="0"/>
                                <ContentPresenter HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentLight}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Overlay close button style -->
        <Style x:Key="OverlayCloseButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Content" Value="&#xE8BB;"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" BorderThickness="0"
                                Width="32" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentLight}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource AppBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- CUSTOM TITLE BAR                                       -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <controls:TitleBarControl x:Name="TitleBarControl" Grid.Row="0"/>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- UPDATE DOWNLOAD PROGRESS BAR                             -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <ProgressBar x:Name="UpdateDownloadBar"
                     Grid.Row="1"
                     Height="3"
                     Minimum="0" Maximum="100"
                     Value="0"
                     Visibility="Collapsed"
                     Opacity="0"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="{DynamicResource Accent}"
                     VerticalAlignment="Top"/>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- MAIN LAYOUT: NAVIGATION VIEW + CONTENT                 -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <!-- ── Content area (Расчёт + overlays) ── -->
            <Grid>
                <!-- ═══════════════════════════════════════ -->
                <!-- PRIMARY: РАСЧЁТ view                    -->
                <!-- ═══════════════════════════════════════ -->
                <Grid x:Name="CalculationView" Background="{DynamicResource AppBg}" Margin="52,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT SIDEBAR -->
                    <controls:SidebarControl x:Name="SidebarControl" Grid.Column="0"/>

                    <!-- RIGHT PANEL -->
                    <Grid Grid.Column="1" Margin="8,8,8,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Action bar -->
                            <RowDefinition Height="Auto"/>  <!-- Quick-Add -->
                            <RowDefinition Height="*"/>     <!-- Table -->
                            <RowDefinition Height="Auto"/>  <!-- ИТОГО -->
                            <RowDefinition Height="Auto"/>  <!-- Status bar -->
                        </Grid.RowDefinitions>

                        <!-- ACTION BAR -->
                        <controls:ActionBarControl x:Name="ActionBarControl" Grid.Row="0"/>

                        <!-- QUICK-ADD -->
                        <controls:QuickAddControl x:Name="QuickAddControl" Grid.Row="1"/>

                        <!-- TABLE + EMPTY STATE -->
                        <controls:OrderItemsControl x:Name="OrderItemsControl" Grid.Row="2"/>

                        <!-- ИТОГО -->
                        <controls:TotalCardControl x:Name="TotalCardControl" Grid.Row="3"/>

                        <!-- Status bar: compact order info + dirty indicator -->
                        <Border Grid.Row="4" Margin="0,6,0,0" Padding="6,3"
                                HorizontalAlignment="Stretch" Background="Transparent">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="StatusOrderInfo" Text="Новый заказ"
                                           FontSize="10" Foreground="{DynamicResource TextMuted}"
                                           VerticalAlignment="Center"/>
                                <Border x:Name="StatusDirtyIndicator" Visibility="Collapsed"
                                        Background="{DynamicResource BadgeWarningBg}"
                                        CornerRadius="7" Padding="7,3" Margin="10,0,0,0"
                                        ToolTip="Несохранённые изменения (Ctrl+S)">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="6" Height="6" Fill="{DynamicResource BadgeWarningFg}"
                                                 VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Есть изменения" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BadgeWarningFg}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ═══════════════════════════════════════ -->
                <!-- OVERLAY: ЗАКАЗЫ                         -->
                <!-- ═══════════════════════════════════════ -->
                <Grid x:Name="OrdersOverlay" Visibility="Collapsed" Panel.ZIndex="15">
                    <!-- Backdrop -->
                    <Border x:Name="OrdersBackdrop" Background="#80000000" Opacity="0"
                            MouseLeftButtonDown="Backdrop_MouseLeftButtonDown" Cursor="Hand"/>
                    <!-- Content panel (slides from right) -->
                    <Border x:Name="OrdersPanel"
                            Background="{DynamicResource Surface}"
                            HorizontalAlignment="Right" Width="800"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1,0,0,0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="OrdersSlideTransform" X="0"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Header -->
                            <Border Grid.Row="0" Background="{DynamicResource HeaderBg}"
                                    Padding="16,10" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE71D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Заказы" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                        <!-- Orders-count badge: chip-style tag next to «Заказы» title.
                                             Previously a flat gray TextBlock on gray header background —
                                             near-invisible ("плохо отображается"). Now an actual chip with
                                             ChipBg (light blue) + Accent bold text + CornerRadius 10, so
                                             the count stands out visually, exactly as the user expects. -->
                                        <Border x:Name="OrdersCountBadge"
                                                Background="{DynamicResource ChipBg}" CornerRadius="10"
                                                Padding="10,4" Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                Visibility="Collapsed">
                                            <TextBlock x:Name="OrdersCountText" Text=""
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Accent}"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                    <Button Style="{StaticResource OverlayCloseButton}"
                                            HorizontalAlignment="Right" Click="CloseOverlay_Click"/>
                                </Grid>
                            </Border>
                            <!-- Content -->
                            <controls:OrdersHistoryControl x:Name="OrdersHistoryControl" Grid.Row="1"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ═══════════════════════════════════════ -->
                <!-- OVERLAY: ЦЕНЫ                           -->
                <!-- ═══════════════════════════════════════ -->
                <Grid x:Name="PricesOverlay" Visibility="Collapsed" Panel.ZIndex="15">
                    <Border x:Name="PricesBackdrop" Background="#80000000" Opacity="0"
                            MouseLeftButtonDown="Backdrop_MouseLeftButtonDown" Cursor="Hand"/>
                    <Border x:Name="PricesPanel"
                            Background="{DynamicResource Surface}"
                            HorizontalAlignment="Right" Width="800"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1,0,0,0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="PricesSlideTransform" X="0"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{DynamicResource HeaderBg}"
                                    Padding="16,10" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE8C7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Цены" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Style="{StaticResource OverlayCloseButton}"
                                            HorizontalAlignment="Right" Click="CloseOverlay_Click"/>
                                </Grid>
                            </Border>
                            <controls:PricesControl x:Name="PricesControl" Grid.Row="1"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ═══════════════════════════════════════ -->
                <!-- OVERLAY: ОБНОВЛЕНИЯ                     -->
                <!-- ═══════════════════════════════════════ -->
                <Grid x:Name="UpdatesOverlay" Visibility="Collapsed" Panel.ZIndex="15">
                    <Border x:Name="UpdatesBackdrop" Background="#80000000" Opacity="0"
                            MouseLeftButtonDown="Backdrop_MouseLeftButtonDown" Cursor="Hand"/>
                    <Border x:Name="UpdatesPanel"
                            Background="{DynamicResource Surface}"
                            HorizontalAlignment="Right" Width="800"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1,0,0,0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="UpdatesSlideTransform" X="0"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{DynamicResource HeaderBg}"
                                    Padding="16,10" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Обновления" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Style="{StaticResource OverlayCloseButton}"
                                            HorizontalAlignment="Right" Click="CloseOverlay_Click"/>
                                </Grid>
                            </Border>
                            <controls:UpdatesTabControl Grid.Row="1"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ── NavigationView (slide-out overlay, 52→160px) ── -->
                <Border x:Name="NavPanel"
                        HorizontalAlignment="Left" Width="52"
                        Panel.ZIndex="10"
                        Background="{DynamicResource Surface}"
                        BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0"
                        ClipToBounds="True"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel VerticalAlignment="Top" Margin="6,8,6,0">
                        <!-- Расчёт -->
                        <Button x:Name="NavBtnCalc" Style="{StaticResource NavButton}" Width="148"
                                ToolTip="Расчёт (Ctrl+1)" Click="NavButton_Click" Tag="Calc">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="30" Height="28">
                                    <TextBlock x:Name="NavIconCalc" Text="&#xE1D0;"
                                               FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="NavLabelCalc" Grid.Column="1" Text="Расчёт" Opacity="0"
                                           Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center"
                                           FontFamily="Segoe UI"/>
                            </Grid>
                        </Button>
                        <!-- Заказы -->
                        <Button x:Name="NavBtnOrders" Style="{StaticResource NavButton}" Width="148"
                                ToolTip="Заказы (Ctrl+2)" Click="NavButton_Click" Tag="Orders" Margin="0,4,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="30" Height="28">
                                    <TextBlock x:Name="NavIconOrders" Text="&#xE71D;"
                                               FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                </Grid>
                                <TextBlock x:Name="NavLabelOrders" Grid.Column="1" Text="Заказы" Opacity="0"
                                           Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center"
                                           FontFamily="Segoe UI"/>
                            </Grid>
                        </Button>
                        <!-- Цены -->
                        <Button x:Name="NavBtnPrices" Style="{StaticResource NavButton}" Width="148"
                                ToolTip="Цены (Ctrl+3)" Click="NavButton_Click" Tag="Prices" Margin="0,4,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="30" Height="28">
                                    <TextBlock x:Name="NavIconPrices" Text="&#xE8C7;"
                                               FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="NavLabelPrices" Grid.Column="1" Text="Цены" Opacity="0"
                                           Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center"
                                           FontFamily="Segoe UI"/>
                            </Grid>
                        </Button>
                        <!-- Обновления -->
                        <Button x:Name="NavBtnUpdates" Style="{StaticResource NavButton}" Width="148"
                                ToolTip="Обновления (Ctrl+4)" Click="NavButton_Click" Tag="Updates" Margin="0,4,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="30" Height="28">
                                    <TextBlock x:Name="NavIconUpdates" Text="&#xE81C;"
                                               FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Ellipse x:Name="NavUpdatesDot" Width="8" Height="8" Fill="#E81123"
                                             HorizontalAlignment="Right" VerticalAlignment="Top"
                                             Margin="0,2,-4,0" Visibility="Collapsed"
                                             ToolTip="Доступна новая версия!"/>
                                </Grid>
                                <TextBlock x:Name="NavLabelUpdates" Grid.Column="1" Text="Обновления" Opacity="0"
                                           Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center"
                                           FontFamily="Segoe UI"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Toast notification container — overlays on top of everything -->
        <Grid x:Name="ToastCanvas" Grid.Row="2" Panel.ZIndex="20" IsHitTestVisible="False"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              ClipToBounds="True"/>
    </Grid>
</Window>
