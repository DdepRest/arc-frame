<Window x:Class="MosquitoNetCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MosquitoNetCalculator.Controls"
        Title="A.R.C. Frame"
        Width="1200" Height="760"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Closing="MainWindow_Closing"
        ResizeMode="CanResize"
        Background="Transparent"
        Foreground="{DynamicResource TextPrimary}"
        Icon="pack://application:,,,/Resources/app_icon.ico"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        SnapsToDevicePixels="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- ГОРЯЧИЕ КЛАВИШИ                                          -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Window.InputBindings>
        <!-- Ctrl+S — сохранить заказ -->
        <KeyBinding Key="S" Modifiers="Control" Command="ApplicationCommands.Save"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Save" Executed="BtnSaveOrder_Click"/>
    </Window.CommandBindings>

    <Grid Background="{DynamicResource AppBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- CUSTOM TITLE BAR                                       -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <controls:TitleBarControl x:Name="TitleBarControl" Grid.Row="0"/>

        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="0">

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- TAB: РАСЧЁТ                                            -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{DynamicResource FluentIconTab}" Text="&#xE1D0;"/>
                        <TextBlock Text="Расчёт" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Background="{DynamicResource AppBg}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT SIDEBAR -->
                    <controls:SidebarControl x:Name="SidebarControl" Grid.Column="0"/>

                    <!-- RIGHT PANEL -->
                    <Grid Grid.Column="1" Margin="8,8,8,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Action bar -->
                            <RowDefinition Height="Auto"/>  <!-- Quick-Add -->
                            <RowDefinition Height="*"/>     <!-- Table -->
                            <RowDefinition Height="Auto"/>  <!-- ИТОГО -->
                        </Grid.RowDefinitions>

                        <!-- ACTION BAR -->
                        <controls:ActionBarControl x:Name="ActionBarControl" Grid.Row="0"/>

                        <!-- QUICK-ADD -->
                        <controls:QuickAddControl x:Name="QuickAddControl" Grid.Row="1"/>

                        <!-- TABLE + EMPTY STATE -->
                        <controls:OrderItemsControl x:Name="OrderItemsControl" Grid.Row="2"/>

                        <!-- ИТОГО -->
                        <controls:TotalCardControl x:Name="TotalCardControl" Grid.Row="3"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- TAB: ЦЕНЫ                                               -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{DynamicResource FluentIconTab}" Text="&#xE8C7;"/>
                        <TextBlock Text="Цены" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <controls:PricesControl x:Name="PricesControl"/>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- TAB: ЗАКАЗЫ                                              -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{DynamicResource FluentIconTab}" Text="&#xE71D;"/>
                        <TextBlock Text="Заказы" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <controls:OrdersHistoryControl x:Name="OrdersHistoryControl"/>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- TAB: ОБНОВЛЕНИЯ                                        -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{DynamicResource FluentIconTab}" Text="&#xE81C;"/>
                        <TextBlock Text="Обновления" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <controls:UpdatesTabControl/>
            </TabItem>

        </TabControl>

        <!-- Toast notification container — overlays on top of everything -->
        <Grid x:Name="ToastCanvas" Grid.Row="1" IsHitTestVisible="False"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              ClipToBounds="True"/>
    </Grid>
</Window>
