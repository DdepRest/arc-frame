<UserControl x:Class="MosquitoNetCalculator.Controls.TitleBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="TitleBar"
            Background="{DynamicResource Surface}"
            Height="40"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
            WindowChrome.IsHitTestVisibleInChrome="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Левая колонка (*): для иконки и заголовка, обрезается TextTrimming. -->
                <ColumnDefinition Width="*"/>
                <!-- Правая колонка (160): ЖЁСТКО фиксированная ширина под 4 кнопки (40×4 = ⚙/Min/Max/Close).
                     TitleBarControl переиспользуется в MainWindow И PrintPreviewWindow — фикс покрывает
                     ОБА случая. В PrintPreview кнопка ⚙ скрыта через ShowSettings="False" → справа остаётся
                     40px «воздуха», это приемлемо при WindowStyle=None.
                     Раньше было Auto — в edge-case (длинный title, DPI>100%) текст заголовка вытеснял
                     кнопки в Auto-колонке. Фиксированная ширина даёт жёсткий резерв. -->
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <!-- Grid вместо StackPanel: жёстко ограничивает ширину TextBlock →
                 TextTrimming работает корректно и заголовок не наезжает на кнопки. -->
            <Grid Grid.Column="0" VerticalAlignment="Center" Margin="12,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Source="{Binding Icon, RelativeSource={RelativeSource AncestorType=Window}}"
                       Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                           VerticalAlignment="Center" Margin="8,0,8,0"
                           Foreground="{DynamicResource TextPrimary}" FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Stretch"/>
            </Grid>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <!-- Settings gear button -->
                <Button x:Name="BtnSettingsGear"
                        Click="BtnSettingsGear_Click"
                        Width="40" Height="40" Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TextPrimary}"
                        ToolTip="Настройки"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                <Grid>
                                    <Border x:Name="HoverOverlay" Background="{DynamicResource AccentLight}" Opacity="0"/>
                                    <Ellipse x:Name="UpdateBadge" Width="9" Height="9" Fill="#E81123"
                                             HorizontalAlignment="Right" VerticalAlignment="Top"
                                             Margin="0,4,4,0" Visibility="Collapsed"
                                             ToolTip="Доступна новая версия!"/>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                 Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                 Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"/>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="SettingsMenu">
                            <MenuItem x:Name="MenuThemeLight" Header="☀  Светлая тема" IsCheckable="True" Click="MenuThemeLight_Click"/>
                            <MenuItem x:Name="MenuThemeDark" Header="🌙  Тёмная тема" IsCheckable="True" Click="MenuThemeDark_Click"/>
                            <Separator/>
                            <MenuItem Header="📍 Сменить точку установки…" Click="MenuChangeLocation_Click"/>
                            <Separator/>
                            <MenuItem Header="🔄 Проверить обновления" Click="MenuCheckUpdates_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <Button x:Name="BtnMinimize" Click="BtnMinimize_Click"
                        Width="40" Height="40" Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TextPrimary}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                <Grid>
                                    <Border x:Name="HoverOverlay" Background="{DynamicResource AccentLight}" Opacity="0"/>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="&#xE738;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                </Button>
                <Button x:Name="BtnMaximize" Click="BtnMaximize_Click"
                        Width="40" Height="40" Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TextPrimary}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                <Grid>
                                    <Border x:Name="HoverOverlay" Background="{DynamicResource AccentLight}" Opacity="0"/>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock x:Name="TxtMaximizeIcon" Text="&#xE739;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                </Button>
                <Button x:Name="BtnClose" Click="BtnClose_Click"
                        Width="40" Height="40" Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TextPrimary}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                <Grid>
                                    <Border x:Name="HoverOverlay" Background="{DynamicResource Danger}" Opacity="0"/>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
