<Window x:Class="MosquitoNetCalculator.Controls.EasterProUpsellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подписка PRO"
        Width="440" Height="540"
        MinHeight="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource Border}" BorderThickness="1"
            CornerRadius="12" Padding="4" Margin="8">
        <Border.Effect>
            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="20" ShadowDepth="2" Opacity="0.12"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar — chrome-consistent with WelcomeWindow -->
            <Border x:Name="TitleBarBorder" Grid.Row="0"
                    Background="{DynamicResource HeaderBg}"
                    CornerRadius="12,12,0,0"
                    Height="32"
                    Padding="14,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock x:Name="TitleBarText"
                               Text="🪄 Подписка PRO"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Button x:Name="BtnClose" Width="32" Height="32"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Right" Click="BtnClose_Click"
                            Foreground="{DynamicResource TextPrimary}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderThickness="0">
                                    <Grid>
                                        <Border x:Name="HoverOverlay" Background="{DynamicResource Danger}" Opacity="0"/>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="1" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content area -->
            <Grid Grid.Row="1" Margin="24,14,24,16">
                <!-- ═══════════════ State 1: PRO upsell ═══════════════ -->
                <Grid x:Name="UpsellState" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                        <TextBlock Text="🪄" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="Автопросчёт откосов"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1"
                               TextWrapping="Wrap"
                               FontSize="13"
                               LineHeight="20"
                               Foreground="{DynamicResource TextSecondary}"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,12,0,16">
                        <Run Text="Автопросчёт откосов доступен по подписке PRO."/>
                        <LineBreak/>
                        <LineBreak/>
                        <Run Text="Оформить подписку за"/>
                        <Run Text=" 350 ₽/мес" FontWeight="SemiBold" Foreground="{DynamicResource Accent}"/>
                        <Run Text=", чтобы разблокировать?"/>
                    </TextBlock>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnPay" Content="Оплатить"
                                Style="{DynamicResource PrimaryButton}"
                                MinWidth="130" Height="36" Margin="0,0,8,0"
                                Padding="16,4"
                                FontSize="13"
                                Click="BtnPay_Click"
                                IsDefault="True"/>
                        <Button x:Name="BtnDecline" Content="Отклонить"
                                Style="{DynamicResource GhostButton}"
                                MinWidth="130" Height="36"
                                Padding="16,4"
                                FontSize="13"
                                IsCancel="True"
                                Click="BtnDecline_Click"/>
                    </StackPanel>
                </Grid>

                <!-- ═══════════════ State 2: joke on Pay ═══════════════ -->
                <!-- Compact 2-row layout (Auto + Auto): StackPanel + Button directly adjacent. -->
                <!-- JokeState has no body text anymore — see BtnPay_Click for SizeToContent=Height. -->
                <Grid x:Name="JokeState" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                        <TextBlock Text="😄" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="Это шутка!"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Row="1"
                            x:Name="BtnContinue"
                            Content="OK"
                            Style="{DynamicResource PrimaryButton}"
                            MinWidth="120" Height="36"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,0"
                            Padding="16,4"
                            FontSize="13"
                            Click="BtnContinue_Click"
                            IsDefault="True"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
