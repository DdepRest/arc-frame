<UserControl x:Class="MosquitoNetCalculator.Controls.PricesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource AppBg}" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource Surface}" CornerRadius="10"
                BorderBrush="{DynamicResource Border}" BorderThickness="1" Margin="8,8,8,6"
                Style="{DynamicResource Card}">
            <Grid>
                <DataGrid x:Name="PriceGrid"
                          ItemsSource="{Binding Prices}"
                          AlternationCount="2"
                          RowBackground="{DynamicResource Surface}"
                          AlternatingRowBackground="{DynamicResource RowAlt}"
                          Margin="2"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True">
                    <DataGrid.RowStyle>
                        <StaticResource ResourceKey="PriceRow"/>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Наименование" Width="*" MinWidth="100"
                                            Binding="{Binding Name}" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Цвет" Width="Auto" MinWidth="65"
                                            Binding="{Binding Color}" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Цена, руб." Width="Auto" MinWidth="75"
                                            Binding="{Binding Price, Converter={StaticResource MoneyConv}, UpdateSourceTrigger=LostFocus}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state for prices list -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            x:Name="PricesEmptyState"
                            Visibility="{Binding IsEmpty, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="48"
                               Foreground="{DynamicResource TextMuted}"
                               Opacity="0.35"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Справочник пуст"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center" Margin="0,10,0,2"/>
                    <TextBlock Text="Добавьте позиции в prices.json или сбросьте цены по умолчанию"
                               FontSize="11"
                               Foreground="{DynamicResource TextMuted}"
                               Opacity="0.85"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,0,8,8">
            <Button Style="{DynamicResource SuccessButton}"
                    Click="BtnSavePrices_Click" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE74E;"/>
                    <TextBlock Text="Сохранить цены"/>
                </StackPanel>
            </Button>
            <Button Style="{DynamicResource DangerButton}"
                    Click="BtnResetPrices_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE777;"/>
                    <TextBlock Text="Сбросить по умолчанию"/>
                </StackPanel>
            </Button>
            <TextBlock VerticalAlignment="Center" Margin="16,0,0,0" FontSize="10"
                       Foreground="{DynamicResource TextMuted}" Text="prices.json"/>
        </StackPanel>
    </Grid>
</UserControl>
