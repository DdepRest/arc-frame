<Window x:Class="MosquitoNetCalculator.Controls.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Доступно обновление"
        Width="460"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Height"
        KeyDown="Window_KeyDown">
    <Border Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource Border}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="8"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="2"
                              Opacity="0.25"
                              Color="{DynamicResource ShadowColor}"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title bar -->
                <RowDefinition Height="Auto"/>  <!-- Version badge -->
                <RowDefinition Height="Auto"/>  <!-- Changelog -->
                <RowDefinition Height="Auto"/>  <!-- Hint -->
                <RowDefinition Height="Auto"/>  <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource HeaderBg}"
                    CornerRadius="12,12,0,0"
                    Height="32"
                    Padding="14,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Доступно обновление"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                    <Button Grid.Column="1"
                            Width="40" Height="40"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="Закрыть (Escape)"
                            Click="CloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="8" ClipToBounds="True">
                                    <Grid>
                                        <Border x:Name="HoverOverlay" Background="{DynamicResource Danger}" Opacity="0" CornerRadius="8"/>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="1" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Version badge -->
            <Border Grid.Row="1"
                    Background="{DynamicResource Accent}"
                    CornerRadius="6"
                    Padding="12,5"
                    HorizontalAlignment="Left"
                    Margin="24,14,24,0">
                <TextBlock x:Name="VersionText"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource OnAccent}"/>
            </Border>

            <!-- Changelog -->
            <ScrollViewer x:Name="ChangelogScroll"
                          Grid.Row="2"
                          MaxHeight="220"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="24,14,24,0">
                <StackPanel x:Name="ChangelogPanel"/>
            </ScrollViewer>

            <TextBlock x:Name="NoChangelogText"
                       Grid.Row="2"
                       Text="Список изменений недоступен."
                       FontSize="12"
                       Foreground="{DynamicResource TextMuted}"
                       FontStyle="Italic"
                       Margin="24,14,24,0"
                       Visibility="Collapsed"/>

            <!-- Hint -->
            <TextBlock Grid.Row="3"
                       Text="Приложение будет перезапущено после установки."
                       FontSize="12"
                       Foreground="{DynamicResource TextMuted}"
                       TextWrapping="Wrap"
                       Margin="24,16,24,0"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="24,20,24,20">
                <Button x:Name="BtnCancel"
                        Content="Отмена"
                        Style="{DynamicResource GhostButton}"
                        MinWidth="90"
                        Padding="16,7"
                        Margin="8,0,0,0"
                        FontSize="13"
                        FontWeight="Normal"
                        Cursor="Hand"
                        IsCancel="True"
                        Click="BtnCancel_Click"/>
                <StackPanel x:Name="DeferHintPanel"
                            Orientation="Vertical"
                            VerticalAlignment="Center"
                            Margin="4,0,0,0"
                            Visibility="Collapsed">
                    <TextBlock Text="Не рекомендуется откладывать"
                               FontSize="10"
                               FontStyle="Italic"
                               Foreground="{DynamicResource TextMuted}"
                               TextWrapping="Wrap"
                               MaxWidth="140"/>
                    <TextBlock Text="обновление надолго"
                               FontSize="10"
                               FontStyle="Italic"
                               Foreground="{DynamicResource TextMuted}"
                               TextWrapping="Wrap"
                               MaxWidth="140"/>
                </StackPanel>
                <Button x:Name="BtnDownload"
                        Content="Скачать и установить"
                        Style="{DynamicResource SuccessButton}"
                        MinWidth="150"
                        Padding="16,7"
                        Margin="8,0,0,0"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsDefault="True"
                        Click="BtnDownload_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
