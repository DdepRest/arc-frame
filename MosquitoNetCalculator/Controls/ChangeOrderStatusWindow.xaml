<Window x:Class="MosquitoNetCalculator.Controls.ChangeOrderStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MosquitoNetCalculator.Models"
        Title=""
        Width="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Height"
        KeyDown="Window_KeyDown">
    <Border Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource Border}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="8"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="2"
                              Opacity="0.25"
                              Color="{DynamicResource ShadowColor}"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title bar -->
                <RowDefinition Height="Auto"/>  <!-- Content -->
                <RowDefinition Height="Auto"/>  <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource HeaderBg}"
                    CornerRadius="12,12,0,0"
                    Height="32"
                    Padding="14,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleText"
                               Grid.Column="0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               TextTrimming="CharacterEllipsis"
                               Text="Изменить статус заказа"/>
                    <Button Grid.Column="1"
                            Width="40" Height="40"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="Закрыть (Escape)"
                            Click="CloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderThickness="0"
                                        CornerRadius="8"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Border x:Name="HoverOverlay"
                                                Background="{DynamicResource Danger}"
                                                Opacity="0"
                                                CornerRadius="8"/>
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="1" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="10"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content: order header + status combo -->
            <StackPanel Grid.Row="1" Margin="24,20,24,12">
                <TextBlock x:Name="OrderHeaderText"
                           FontWeight="Bold"
                           FontSize="14"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,12"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="Новый статус:"
                           FontSize="12"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,6"/>
                <ComboBox x:Name="StatusCombo"
                          ItemsSource="{x:Static models:OrderStatuses.All}"
                          FontSize="13"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="24,0,24,20">
                <Button x:Name="BtnCancel"
                        Style="{DynamicResource GhostButton}"
                        Content="Отмена"
                        MinWidth="90"
                        Padding="16,7"
                        Margin="0,0,8,0"
                        FontSize="13"
                        Click="BtnCancel_Click"
                        IsCancel="True"/>
                <Button x:Name="BtnSave"
                        Style="{DynamicResource PrimaryButton}"
                        Content="Сохранить"
                        MinWidth="90"
                        Padding="16,7"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Click="BtnSave_Click"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
