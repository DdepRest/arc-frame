<UserControl x:Class="MosquitoNetCalculator.Controls.OrderItemsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Border x:Name="CardTable" Background="{DynamicResource Surface}" CornerRadius="10"
                BorderBrush="{DynamicResource Border}" BorderThickness="1"
                Opacity="0"
                ClipToBounds="True">
            <Border.Clip>
                <RectangleGeometry Rect="0,0,10000,10000" RadiusX="10" RadiusY="10"/>
            </Border.Clip>
            <DataGrid x:Name="OrderGrid"
                      ItemsSource="{Binding OrderItems}"
                      Margin="0"
                      Background="Transparent"
                      RowBackground="Transparent"
                      AlternatingRowBackground="Transparent"
                      HorizontalGridLinesBrush="{DynamicResource Border}"
                      VerticalGridLinesBrush="Transparent"
                      BorderThickness="0"
                      RowHeaderWidth="0"
                      CanUserReorderColumns="False"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True">
                <DataGrid.RowStyle>
                    <StaticResource ResourceKey="OrderRow"/>
                </DataGrid.RowStyle>
                <DataGrid.Resources>
                    <Style x:Key="RightCell" TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Right"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                    <Style x:Key="CenterCell" TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- Вкл. -->
                    <DataGridTemplateColumn Header="" Width="54">
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="Transparent" BorderThickness="0" SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0" SnapsToDevicePixels="True"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- № -->
                    <DataGridTextColumn Header="&#x2116;" Width="Auto" MinWidth="32"
                                                            Binding="{Binding RowNumber}"
                                                            IsReadOnly="True"
                                                            ElementStyle="{DynamicResource CenterCell}"/>

                    <!-- Наименование (Anwis mode pill inline) -->
                    <DataGridTemplateColumn Header="Наименование" Width="*" MinWidth="80" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimary}" FontWeight="Medium"
                                               TextWrapping="Wrap"/>
                                    <Border Background="{DynamicResource Accent}" CornerRadius="5"
                                            Padding="8,2" Margin="6,0,0,0" Cursor="Hand"
                                            Visibility="{Binding IsAnwis, Converter={StaticResource BoolToVis}}"
                                            ToolTip="{Binding AnwisSizeToolTip}"
                                            PreviewMouseRightButtonDown="AnwisModePill_PreviewRightClick">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding AnwisSizeShortLabel}"
                                                   FontSize="10.5" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource OnAccent}"/>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Цвет -->
                    <DataGridTextColumn Header="Цвет" Width="Auto" MinWidth="55"
                                                            Binding="{Binding Color}"
                                                            IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>


                    <!-- Ширина (editable with auto-recalc) -->
                    <DataGridTextColumn Header="Ширина" Width="Auto" MinWidth="70">
                        <DataGridTextColumn.Binding>
                            <Binding Path="ШиринаВвод" Converter="{StaticResource DimConv}" ConverterParameter=" мм" UpdateSourceTrigger="PropertyChanged"/>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background" Value="{DynamicResource Surface}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <EventSetter Event="GotFocus" Handler="SelectAll_OnFocus"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>

                    <!-- Высота (editable with auto-recalc) -->
                    <DataGridTextColumn Header="Высота" Width="Auto" MinWidth="70">
                        <DataGridTextColumn.Binding>
                            <Binding Path="ВысотаВвод" Converter="{StaticResource DimConv}" ConverterParameter=" мм" UpdateSourceTrigger="PropertyChanged"/>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background" Value="{DynamicResource Surface}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <EventSetter Event="GotFocus" Handler="SelectAll_OnFocus"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>

                    <!-- Монтаж (toggle per row) -->
                    <DataGridTemplateColumn Header="Монтаж" Width="Auto" MinWidth="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding InstallationDisplay}"
                                        FontSize="14" FontWeight="Bold"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" HorizontalAlignment="Center"
                                        Foreground="{Binding InstallationForegroundColor}"
                                        Click="BtnToggleInstallation_Click"
                                        ToolTip="{Binding InstallationToolTip}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Кол-во (editable) -->
                    <DataGridTextColumn Header="Кол-во" Width="Auto" MinWidth="55">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Quantity" UpdateSourceTrigger="PropertyChanged"/>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CenterCell}"/>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background" Value="{DynamicResource Surface}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <EventSetter Event="GotFocus" Handler="SelectAll_OnFocus"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>

                    <!-- Площ./Дл. -->
                    <DataGridTextColumn Header="Площ./Дл." Width="Auto" MinWidth="70"
                                                            Binding="{Binding CalculatedValueDisplay}"
                                                            IsReadOnly="True"
                                                            ElementStyle="{DynamicResource RightCell}"/>

                    <!-- Цена (editable — user can override the unit price per row) -->
                    <DataGridTextColumn Header="Цена" Width="Auto" MinWidth="70">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Price" Converter="{StaticResource MoneyConv}" UpdateSourceTrigger="LostFocus"/>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource RightCell}">
                                <Setter Property="Margin" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background" Value="{DynamicResource Surface}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <EventSetter Event="GotFocus" Handler="SelectAll_OnFocus"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>

                    <!-- Сумма (read-only, auto-calculated) -->
                    <DataGridTextColumn Header="Сумма" Width="Auto" MinWidth="70"
                                                            Binding="{Binding TotalDisplay}"
                                                            IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource RightCell}">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="Margin" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- x Delete -->
                    <DataGridTemplateColumn MinWidth="32" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Style="{DynamicResource DeleteRowButton}"
                                        Click="BtnDeleteRow_Click"
                                        ToolTip="Удалить">
                                    <Path Data="M3,3 L9,9 M9,3 L3,9" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="10" Height="10" Stretch="Uniform"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Empty state -->
        <Border x:Name="EmptyState" Background="{DynamicResource Surface}" CornerRadius="10"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                BorderBrush="{DynamicResource Border}" BorderThickness="1"
                Opacity="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Visibility, RelativeSource={RelativeSource Self}}" Value="Visible">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1"
                                                         Duration="0:0:0.35">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,40">
                <Path Data="M8,1 A7,7 0 1,0 8,15 A7,7 0 1,0 8,1 Z M5,8 L11,8 M8,5 L8,11" 
                      Width="34" Height="34" Stretch="Uniform"
                      Stroke="{DynamicResource Border}" StrokeThickness="1.2" Fill="Transparent"
                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Позиций пока нет" FontSize="14"
                           FontWeight="Medium" Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Выберите тип, укажите размеры и нажмите &quot;Добавить&quot;"
                           FontSize="11" Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
