<UserControl x:Class="MosquitoNetCalculator.Controls.OrderItemsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Border x:Name="CardTable" Background="{DynamicResource Surface}" CornerRadius="10"
                BorderBrush="{DynamicResource Border}" BorderThickness="1"
                Opacity="0"
                ClipToBounds="True">
            <Border.Clip>
                <RectangleGeometry Rect="0,0,10000,10000" RadiusX="10" RadiusY="10"/>
            </Border.Clip>
            <DataGrid x:Name="OrderGrid"
                      ItemsSource="{Binding OrderItems}"
                      MouseDoubleClick="OrderGrid_MouseDoubleClick"
                      Margin="0"
                      Background="Transparent"
                      RowBackground="Transparent"
                      AlternatingRowBackground="Transparent"
                      HorizontalGridLinesBrush="{DynamicResource Border}"
                      VerticalGridLinesBrush="Transparent"
                      BorderThickness="0"
                      RowHeaderWidth="0"
                      CanUserReorderColumns="False"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True">
                <DataGrid.RowStyle>
                    <StaticResource ResourceKey="OrderRow"/>
                </DataGrid.RowStyle>
                <DataGrid.Resources>
                    <Style x:Key="RightCell" TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Right"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                    <Style x:Key="CenterCell" TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- Вкл. -->
                    <!-- v3.43.4 (bugfix): IsReadOnly=True ОБЯЗАТЕЛЬНО — без него клик
                         по CheckBox уводит DataGrid в режим редактирования ячейки,
                         что вызывает BeginningEdit → PushUndo() и ломает штатный
                         two-way binding IsChecked↔IsActive (визуально checkbox не
                         переключается или проскакивает мимо). С IsReadOnly=True
                         DataGrid пропускает edit-lifecycle, и CheckBox сам
                         обрабатывает клик через свою штатную логику. -->
                    <DataGridTemplateColumn Header="" Width="54" IsReadOnly="True">
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{StaticResource FluentFocusVisual}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="Transparent" BorderThickness="0" SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0" SnapsToDevicePixels="True"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- № -->
                    <DataGridTextColumn Header="&#x2116;" Width="Auto" MinWidth="32"
                                                            Binding="{Binding RowNumber}"
                                                            IsReadOnly="True"
                                                            ElementStyle="{DynamicResource CenterCell}"/>

                    <!-- Наименование (Anwis mode pill inline) -->
                    <DataGridTemplateColumn Header="Наименование" Width="*" MinWidth="80" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimary}" FontWeight="Medium"
                                               TextWrapping="Wrap"/>
                                    <Border Background="{DynamicResource AccentLight}" CornerRadius="4"
                                            Padding="7,2" Margin="6,0,0,0" Cursor="Hand"
                                            Visibility="{Binding IsAnwis, Converter={StaticResource BoolToVis}}"
                                            ToolTip="{Binding AnwisSizeToolTip}"
                                            PreviewMouseLeftButtonDown="AnwisModePill_PreviewLeftClick"
                                            PreviewMouseRightButtonDown="AnwisModePill_PreviewRightClick">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Accent}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding AnwisSizeShortLabel}"
                                                   FontSize="10" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Цвет -->
                    <DataGridTextColumn Header="Цвет" Width="Auto" MinWidth="55"
                                                            Binding="{Binding Color}"
                                                            IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>


                    <!-- Ширина (v3.37.2 (GOTCHAS#15): LostFocus — формула ББ60/ББ70 не срабатывает
                         на каждом нажатии клавиши. При PropertyChanged набор «1» → raw=1 →
                         max(0,1−30)=0 → reverse=30 → ячейка перезаписывается «30», следующий
                         символ дописывается → «301200». LostFocus применяет формулу один раз при уходе
                         из ячейки. Auto-width для 3-4 значных размеров не критичен.) -->
                    <DataGridTextColumn Header="Ширина" Width="Auto" MinWidth="70">
                        <DataGridTextColumn.Binding>
                            <Binding Path="ШиринаВвод" Converter="{StaticResource DimConv}" ConverterParameter=" мм" UpdateSourceTrigger="LostFocus"/>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background" Value="{DynamicResource Surface}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <!-- v3.37.2 (GOTCHAS#14): synchronous SelectAll — see SelectAll_OnFocus comment. -->
                                <EventSetter Event="GotFocus" Handler="SelectAll_OnFocus"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>

                    <!-- Высота (v3.37.2 (GOTCHAS#15): LostFocus — см. комментарий на Ширине.) -->
                    <DataGridTextColumn Header="Высота" Width="Auto" MinWidth="70">
                        <DataGridTextColumn.Binding>
                            <Binding Path="ВысотаВвод" Converter="{StaticResource DimConv}" ConverterParameter=" мм" UpdateSourceTrigger="LostFocus"/>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background" Value="{DynamicResource Surface}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <!-- v3.37.2 (GOTCHAS#14): synchronous SelectAll — see SelectAll_OnFocus comment. -->
                                <EventSetter Event="GotFocus" Handler="SelectAll_OnFocus"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>

                    <!-- Монтаж (toggle per row) -->
                    <DataGridTemplateColumn Header="Монтаж" Width="Auto" MinWidth="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding InstallationDisplay}"
                                        FontSize="14" FontWeight="Bold"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" HorizontalAlignment="Center"
                                        Foreground="{Binding InstallationForegroundColor}"
                                        Click="BtnToggleInstallation_Click"
                                        ToolTip="{Binding InstallationToolTip}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Кол-во (editable; hidden for amount-only products) -->
                    <DataGridTextColumn Header="Кол-во" Width="Auto" MinWidth="55">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Quantity" UpdateSourceTrigger="PropertyChanged"/>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CenterCell}">
                                <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAmountOnly}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsQuantityOptional}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background" Value="{DynamicResource Surface}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <EventSetter Event="GotFocus" Handler="SelectAll_OnFocus"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>

                    <!-- Площ./Дл. (hidden for amount-only products) -->
                    <DataGridTextColumn Header="Площ./Дл." Width="Auto" MinWidth="70"
                                                            Binding="{Binding CalculatedValueDisplay}"
                                                            IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource RightCell}">
                                <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAmountOnly}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsQuantityOptional}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Цена (editable — user can override the unit price per row).
                         PropertyChanged (not LostFocus) — required for Width="Auto" to grow
                         while user types. See docs/arc/GOTCHAS.md#13. -->
                    <DataGridTextColumn Header="Цена" Width="Auto" MinWidth="70">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Price" Converter="{StaticResource MoneyConv}" UpdateSourceTrigger="PropertyChanged"/>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource RightCell}">
                                <Setter Property="Margin" Value="6,0"/>
                                <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background" Value="{DynamicResource Surface}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <EventSetter Event="GotFocus" Handler="SelectAll_OnFocus"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>

                    <!-- Сумма (read-only, auto-calculated) -->
                    <DataGridTextColumn Header="Сумма" Width="Auto" MinWidth="70"
                                                            Binding="{Binding TotalDisplay}"
                                                            IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource RightCell}">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="Margin" Value="6,0"/>
                                <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- x Delete -->
                    <DataGridTemplateColumn MinWidth="32" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Style="{DynamicResource DeleteRowButton}"
                                        Click="BtnDeleteRow_Click"
                                        ToolTip="Удалить">
                                    <Path Data="M3,3 L9,9 M9,3 L3,9" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="10" Height="10" Stretch="Uniform"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Empty state — Fluent illustration with clear action guidance -->
        <Border x:Name="EmptyState" Background="{DynamicResource Surface}" CornerRadius="10"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                BorderBrush="{DynamicResource Border}" BorderThickness="1"
                Opacity="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Visibility, RelativeSource={RelativeSource Self}}" Value="Visible">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1"
                                                         Duration="0:0:0.35">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,0,20,30" MaxWidth="700">
                <!-- Header icon + title -->
                <Path Data="M2,2 L14,2 L14,14 L2,14 Z M2,7 L14,7 M7,2 L7,14"
                      Width="40" Height="40" Stretch="Uniform"
                      Stroke="{DynamicResource Border}" StrokeThickness="1.2" Fill="Transparent"
                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      HorizontalAlignment="Center" Margin="0,0,0,10"
                      Opacity="0.6"/>
                <TextBlock Text="Выберите товар" FontSize="15"
                           FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                           HorizontalAlignment="Center" Margin="0,0,0,4" Opacity="0.85"/>
                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondary}" Opacity="0.85"
                           HorizontalAlignment="Center" Margin="0,0,0,14" TextAlignment="Center">
                    <Run Text="Нажмите на товар — он появится в поле"/>
                    <Run Text=" «Тип»" Foreground="{DynamicResource Accent}" FontWeight="SemiBold"/>
                    <Run Text=" выше"/>
                </TextBlock>

                <!-- Product chips grid — populated from code-behind -->
                <ItemsControl x:Name="ProductChipsList" Margin="0,0,0,0" IsTabStop="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource Surface}" CornerRadius="8"
                                    BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                    Padding="14,8" Margin="4,4" Cursor="Hand"
                                    SnapsToDevicePixels="True">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentLight}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding}" FontSize="12.5" FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimary}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Subtle hint at bottom -->
                <TextBlock FontSize="10" Foreground="{DynamicResource TextPrimary}" Opacity="0.7"
                           HorizontalAlignment="Center" Margin="0,12,0,0">
                    <Run Text="или используйте"/>
                    <Run Text=" поиск" Foreground="{DynamicResource Accent}"/>
                    <Run Text=" выше"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
