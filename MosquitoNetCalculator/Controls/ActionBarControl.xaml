<UserControl x:Class="MosquitoNetCalculator.Controls.ActionBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="CardActionBar" Background="{DynamicResource Surface}" CornerRadius="10"
            Padding="14,9" Margin="0,0,0,8"
            BorderBrush="{DynamicResource Border}" BorderThickness="1"
            Style="{DynamicResource Card}" Opacity="0">
        <Grid>
            <!-- Cluster 1+2: Primary + Secondary (left) -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Cluster 1: Primary -->
                <Button Style="{DynamicResource PrimaryButton}"
                        Click="BtnPrintKp_Click" Margin="0,0,6,0"
                        ToolTip="Печать коммерческого предложения">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE2F6;"/>
                        <TextBlock Text="Печать КП"/>
                    </StackPanel>
                </Button>
                <Button Style="{DynamicResource SuccessButton}"
                        Click="BtnSaveOrder_Click" Margin="0,0,6,0"
                        ToolTip="Сохранить заказ (Ctrl+S)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE74E;"/>
                        <TextBlock Text="Сохранить"/>
                    </StackPanel>
                </Button>
                <Button Style="{DynamicResource PrimaryButton}"
                        Click="BtnOrderInfo_Click" Margin="0,0,6,0"
                        ToolTip="Заполните: имя, телефон, адрес, номер договора, примечания">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE77B;"/>
                        <TextBlock Text="Заказчик"/>
                    </StackPanel>
                </Button>

                <!-- Separator -->
                <Rectangle Width="1" Height="20" Fill="{DynamicResource Border}" Margin="8,0"/>

                <!-- Cluster 2: Secondary -->
                <Button Style="{DynamicResource GhostButton}"
                        Click="BtnNewOrder_Click" Margin="0,0,6,0"
                        ToolTip="Создать новый заказ (сначала сохраните текущий)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE710;"/>
                        <TextBlock Text="Новый заказ"/>
                    </StackPanel>
                </Button>
                <Button Style="{DynamicResource GhostButton}"
                        Click="BtnSendToFactory_Click" Margin="0,0,6,0"
                        ToolTip="Сформировать текст для отправки на завод / копирования">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE7B3;"/>
                        <TextBlock Text="На завод"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Cluster 3: Danger/Tertiary (right) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{DynamicResource DangerGhostButton}"
                        Click="BtnClearAll_Click"
                        ToolTip="Очистить все позиции из текущего расчёта">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE75C;"/>
                        <TextBlock Text="Очистить всё"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
