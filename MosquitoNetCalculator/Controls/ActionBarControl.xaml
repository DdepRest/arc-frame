<UserControl x:Class="MosquitoNetCalculator.Controls.ActionBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="CardActionBar" Background="{DynamicResource Surface}" CornerRadius="10"
            Padding="14,9" Margin="0,0,0,8"
            BorderBrush="{DynamicResource Border}" BorderThickness="1"
            Style="{DynamicResource Card}" Opacity="0">
        <Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{DynamicResource PrimaryButton}"
                        Click="BtnPrintKp_Click" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE2F6;"/>
                        <TextBlock Text="Печать КП"/>
                    </StackPanel>
                </Button>
                <Button Style="{DynamicResource SuccessButton}"
                        Click="BtnSaveOrder_Click" Margin="0,0,8,0"
                        ToolTip="Сохранить заказ (Ctrl+S)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE74E;"/>
                        <TextBlock Text="Сохранить"/>
                    </StackPanel>
                </Button>
                <Button Style="{DynamicResource GhostButton}"
                        Click="BtnNewOrder_Click" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE710;"/>
                        <TextBlock Text="Новый заказ"/>
                    </StackPanel>
                </Button>
                <Button Style="{DynamicResource GhostButton}"
                        Click="BtnSendToFactory_Click" Margin="0,0,8,0"
                        ToolTip="Сформировать текст для отправки на завод / копирования">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE7B3;"/>
                        <TextBlock Text="На завод"/>
                    </StackPanel>
                </Button>
                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="8,0,0,0">
                    <Run x:Name="RunCurrentOrderInfo" Text="Новый заказ"/>
                </TextBlock>
                <Border x:Name="DirtyIndicator" Visibility="Collapsed" Background="{DynamicResource BadgeWarningBg}" CornerRadius="8" Padding="10,4" Margin="10,0,0,0" VerticalAlignment="Center" ToolTip="В текущем расчёте есть несохранённые изменения. Нажмите «Сохранить» (Ctrl+S).">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="DirtyDot" Width="7" Height="7" Fill="{DynamicResource BadgeWarningFg}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="Есть изменения" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource BadgeWarningFg}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <!-- Download progress bar — visible only during update download.
                     Sits right above the Settings button as a compact progress
                     indicator with a ProgressBar + percentage label. -->
                <Border x:Name="DownloadProgressPanel"
                        Visibility="Collapsed"
                        Background="{DynamicResource SectionBg}"
                        CornerRadius="6"
                        Padding="10,6"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ProgressBar x:Name="DownloadBar"
                                         Minimum="0" Maximum="100"
                                         Value="0"
                                         Height="6"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"/>
                            <TextBlock x:Name="DownloadPercentText"
                                       Grid.Column="1"
                                       Text="0%"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Accent}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="DownloadLabel"
                                   Text="Загрузка обновления..."
                                   FontSize="10"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
                <Button x:Name="BtnSettings"
                        Style="{DynamicResource GhostButton}"
                        Margin="0,0,8,0"
                        Click="BtnSettings_Click"
                        ToolTip="Настройки программы (тема, точка установки)">
                    <!-- Update badge: red dot when new version is available -->
                    <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE713;"/>
                        <TextBlock Text="Настройки"/>
                    </StackPanel>
                    <Ellipse x:Name="UpdateBadge"
                             Width="9" Height="9"
                             Fill="#E81123"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-2,-4,0"
                             Visibility="Collapsed"
                             ToolTip="Доступна новая версия!"/>
                    </Grid>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="SettingsMenu">
                            <MenuItem x:Name="MenuThemeLight"
                                      Header="Светлая тема"
                                      IsCheckable="True"
                                      Click="MenuThemeLight_Click"/>
                            <MenuItem x:Name="MenuThemeDark"
                                      Header="Тёмная тема"
                                      IsCheckable="True"
                                      Click="MenuThemeDark_Click"/>
                            <Separator/>
                            <MenuItem Header="Сменить точку установки…"
                                      Click="MenuChangeLocation_Click"/>
                            <Separator/>
                            <MenuItem x:Name="MenuFlowToggle"
                                      Header="Автообновления (Velopack Flow)"
                                      IsCheckable="True"
                                      Click="MenuFlowToggle_Click"/>
                            <Separator/>
                            <MenuItem Header="Проверить обновления"
                                      Click="MenuCheckUpdates_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <Button Style="{DynamicResource DangerGhostButton}"
                        Click="BtnClearAll_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE75C;"/>
                        <TextBlock Text="Очистить всё"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
