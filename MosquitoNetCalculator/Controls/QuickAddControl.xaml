<UserControl x:Class="MosquitoNetCalculator.Controls.QuickAddControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Anwis segmented control: shared segment styles -->
        <Style x:Key="SegText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        </Style>
        <Style x:Key="SegBase" TargetType="Border">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style x:Key="SegLeft" TargetType="Border" BasedOn="{StaticResource SegBase}">
            <Setter Property="CornerRadius" Value="6,0,0,6"/>
        </Style>
        <Style x:Key="SegMid" TargetType="Border" BasedOn="{StaticResource SegBase}">
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style x:Key="SegRight" TargetType="Border" BasedOn="{StaticResource SegBase}">
            <Setter Property="CornerRadius" Value="0,6,6,0"/>
        </Style>
    </UserControl.Resources>
    <Border x:Name="CardQuickAdd" Background="{DynamicResource QuickBg}" CornerRadius="10"
            Padding="16,12" Margin="0,0,0,8"
            BorderBrush="{DynamicResource Border}" BorderThickness="1"
            Style="{DynamicResource Card}" Opacity="0">
        <StackPanel>
            <!-- Header: title + keyboard hints -->
            <Grid Margin="0,0,0,8">
                <TextBlock Grid.Column="0" Text="Добавить позицию" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Opacity="0.85"/>
            </Grid>

            <!-- Search row -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Поиск" VerticalAlignment="Center"
                           FontSize="10.5" Foreground="{DynamicResource TextSecondary}" Margin="0,0,6,0"/>
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtQuickSearch" Grid.Column="0" Style="{DynamicResource QuickInput}"
                             VerticalContentAlignment="Center"
                             TextChanged="TxtQuickSearch_TextChanged"
                             KeyDown="TxtQuickSearch_KeyDown"
                             GotFocus="SelectAll_OnFocus"
                             LostFocus="TxtQuickSearch_LostFocus"/>
                    <Popup x:Name="SearchPopup" AllowsTransparency="True" IsOpen="False"
                           Placement="Bottom" PlacementTarget="{Binding ElementName=TxtQuickSearch}"
                           PopupAnimation="Slide" StaysOpen="True">
                        <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}"
                                BorderThickness="1" CornerRadius="6" Margin="0,2,0,0" Padding="4,4"
                                SnapsToDevicePixels="True" MinWidth="220" MaxHeight="260">
                            <ListBox x:Name="SearchSuggestions" BorderThickness="0" Background="Transparent"
                                     SelectionChanged="SearchSuggestions_SelectionChanged"
                                     PreviewMouseDown="SearchSuggestions_PreviewMouseDown" FontSize="12">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="FocusVisualStyle" Value="{StaticResource FluentFocusVisual}"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            BorderThickness="0" CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                                        <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
                                                        </Trigger>
                                                        <MultiTrigger>
                                                            <MultiTrigger.Conditions>
                                                                <Condition Property="IsSelected" Value="True"/>
                                                                <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                                            </MultiTrigger.Conditions>
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentLight}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                        </MultiTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentLight}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>
                    </Popup>
                    <Button x:Name="BtnClearQuickSearch" Grid.Column="1"
                            Style="{DynamicResource GhostButton}"
                            Content="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            FontSize="10" Padding="4,2" Margin="4,0,0,0" Cursor="Hand"
                            Visibility="Collapsed"
                            Click="BtnClearQuickSearch_Click"
                            ToolTip="Очистить поиск"/>
                </Grid>
            </Grid>

            <!-- Fields with group labels -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/> <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="1*"/> <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="1*"/> <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="1*"/> <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="0.5*"/> <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="0.7*"/> <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Group labels -->
                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Text="Товар"
                           FontSize="8" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,2"/>
                <TextBlock Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="3" Text="Размеры"
                           FontSize="8" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,2"/>
                <TextBlock Grid.Row="0" Grid.Column="8" Grid.ColumnSpan="3" Text="Кол-во и цена"
                           FontSize="8" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,2"/>

                <!-- Field row -->
                <StackPanel Grid.Row="1" Grid.Column="0">
                    <TextBlock Text="Тип" Style="{DynamicResource FieldLabel}"/>
                    <ComboBox x:Name="CmbQuickType" Style="{DynamicResource QuickCombo}"
                              SelectionChanged="CmbQuickType_SelectionChanged"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2">
                    <TextBlock Text="Цвет" Style="{DynamicResource FieldLabel}"/>
                    <ComboBox x:Name="CmbQuickColor" Style="{DynamicResource QuickCombo}"
                              SelectionChanged="CmbQuickColor_SelectionChanged"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="4">
                    <TextBlock Text="Ширина, мм" Style="{DynamicResource FieldLabel}"/>
                    <TextBox x:Name="TxtQuickWidth" Style="{DynamicResource QuickInput}"
                             TextChanged="QuickField_TextChanged"
                             KeyDown="QuickField_KeyDown"
                             GotFocus="QuickField_GotFocus"
                             LostFocus="QuickField_LostFocus"
                             HorizontalContentAlignment="Right"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="6">
                    <TextBlock Text="Высота, мм" Style="{DynamicResource FieldLabel}"/>
                    <TextBox x:Name="TxtQuickHeight" Style="{DynamicResource QuickInput}"
                             TextChanged="QuickField_TextChanged"
                             KeyDown="QuickField_KeyDown"
                             GotFocus="QuickField_GotFocus"
                             LostFocus="QuickField_LostFocus"
                             HorizontalContentAlignment="Right"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="8">
                    <TextBlock Text="Кол-во" Style="{DynamicResource FieldLabel}"/>
                    <TextBox x:Name="TxtQuickQty" Text="1" Style="{DynamicResource QuickInput}"
                             TextChanged="QuickField_TextChanged"
                             GotFocus="SelectAll_OnFocus"
                             LostFocus="QuickField_LostFocus"
                             HorizontalContentAlignment="Right"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="10">
                    <TextBlock Text="Цена, руб." Style="{DynamicResource FieldLabel}"/>
                    <TextBox x:Name="TxtQuickPrice" Style="{DynamicResource QuickInput}"
                             TextChanged="QuickField_TextChanged"
                             LostFocus="TxtQuickPrice_LostFocus"
                             GotFocus="SelectAll_OnFocus"
                             HorizontalContentAlignment="Right"/>
                </StackPanel>
                <!-- Антикошка toggle — отдельная строка на всю ширину «Товар» -->
                <ToggleButton x:Name="TbtnAnticat"
                              Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                              Content="Антикошка  +2000 ₽/м²"
                              FontSize="11" FontWeight="SemiBold"
                              HorizontalAlignment="Left"
                              Margin="0,4,0,0" Padding="10,5"
                              Visibility="Collapsed"
                              Click="TbtnAnticat_Click">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Background" Value="{DynamicResource Surface}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource Accent}"/>
                                                <Setter TargetName="Bd" Property="BorderBrush"
                                                        Value="{DynamicResource Accent}"/>
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource OnAccent}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource AccentLight}"/>
                                                <Setter TargetName="Bd" Property="BorderBrush"
                                                        Value="{DynamicResource Accent}"/>
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource Accent}"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                    <Condition Property="IsChecked" Value="True"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource AccentHover}"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

                <!-- Pinned to Top + 17px margin so it aligns with the top of the
                     adjacent TextBox/ComboBox controls (after the FieldLabel takes
                     ~17px of vertical space). Previous Bottom anchoring shifted
                     down whenever the Антикошка ToggleButton appeared and grew
                     the row height. -->
                <Button x:Name="BtnAdd" Grid.Row="1" Grid.Column="12" Style="{DynamicResource CompactAddButton}"
                        Click="BtnQuickAdd_Click" ToolTip="Добавить (Enter)"
                        VerticalAlignment="Top" Margin="0,17,0,0" Height="32">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE710;"/>
                        <TextBlock Text="Добавить"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Anwis segmented control — appears only when applicable -->
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <StackPanel x:Name="PanelAnwisModes"
                            Orientation="Horizontal"
                            Visibility="Collapsed"
                            Opacity="0">
                <StackPanel.RenderTransform>
                    <TranslateTransform X="0" Y="0"/>
                </StackPanel.RenderTransform>
                <Border Background="{DynamicResource SubtleBorder}"
                        CornerRadius="7" ClipToBounds="True">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="PillBB60" Style="{DynamicResource SegLeft}" Cursor="Hand"
                                PreviewMouseLeftButtonDown="AnwisModePill_Click">
                            <TextBlock Text="ББ 60" Style="{DynamicResource SegText}"/>
                        </Border>
                        <Rectangle x:Name="Sep1" Width="1" Fill="{DynamicResource SubtleBorder}"/>
                        <Border x:Name="PillBB70" Style="{DynamicResource SegMid}" Cursor="Hand"
                                PreviewMouseLeftButtonDown="AnwisModePill_Click">
                            <TextBlock Text="ББ 70" Style="{DynamicResource SegText}"/>
                        </Border>
                        <Rectangle x:Name="Sep2" Width="1" Fill="{DynamicResource SubtleBorder}"/>
                        <Border x:Name="PillPP" Style="{DynamicResource SegMid}" Cursor="Hand"
                                PreviewMouseLeftButtonDown="AnwisModePill_Click">
                            <TextBlock Text="ПП" Style="{DynamicResource SegText}"/>
                        </Border>
                        <Rectangle x:Name="Sep3" Width="1" Fill="{DynamicResource SubtleBorder}"/>
                        <Border x:Name="PillProem" Style="{DynamicResource SegMid}" Cursor="Hand"
                                PreviewMouseLeftButtonDown="AnwisModePill_Click">
                            <TextBlock Text="Проём" Style="{DynamicResource SegText}"/>
                        </Border>
                        <Rectangle x:Name="Sep4" Width="1" Fill="{DynamicResource SubtleBorder}"/>
                        <Border x:Name="PillGab" Style="{DynamicResource SegRight}" Cursor="Hand"
                                PreviewMouseLeftButtonDown="AnwisModePill_Click">
                            <TextBlock Text="Габарит" Style="{DynamicResource SegText}"/>
                        </Border>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="TxtAnwisModeHint" FontSize="11" FontWeight="SemiBold" Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </StackPanel>

            <Border x:Name="PreviewChip" Background="{DynamicResource ChipBg}"
                    CornerRadius="5" Padding="8,5" HorizontalAlignment="Left"
                    Margin="0,8,0,0" Visibility="Collapsed">
                <TextBlock x:Name="TxtQuickPreview" FontSize="11"
                           Foreground="{DynamicResource Accent}"/>
            </Border>

        </StackPanel>
    </Border>
</UserControl>
