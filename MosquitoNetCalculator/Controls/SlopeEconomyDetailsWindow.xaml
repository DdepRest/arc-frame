<Window x:Class="MosquitoNetCalculator.Controls.SlopeEconomyDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали экономии"
        Width="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Height"
        KeyDown="Window_KeyDown">
    <Border Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource Border}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="8"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="2"
                              Opacity="0.25"
                              Color="{DynamicResource ShadowColor}"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title bar -->
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Table -->
                <RowDefinition Height="Auto"/>  <!-- Total -->
                <RowDefinition Height="Auto"/>  <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource HeaderBg}"
                    CornerRadius="12,12,0,0"
                    Height="32"
                    Padding="14,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Детали экономии"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                    <Button Grid.Column="1"
                            Width="40" Height="40"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="Закрыть (Escape)"
                            Click="CloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="8" ClipToBounds="True">
                                    <Grid>
                                        <Border x:Name="HoverOverlay" Background="{DynamicResource Danger}" Opacity="0" CornerRadius="8"/>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="1" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Header -->
            <StackPanel Grid.Row="1" Margin="24,18,24,0">
                <TextBlock Text="Расчёт экономии по всем откосам в заказе"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="TxtTotalSlopes"
                           FontSize="11"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Table -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="24,14,24,0"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Header -->
                        <RowDefinition Height="Auto"/>  <!-- Rows -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Background="{DynamicResource HeaderBg}" Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Материал" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="10,8,4,8" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Без экон." FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" Margin="4,8,10,8" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="С экон." FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" Margin="4,8,10,8" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Экон." FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" Margin="4,8,10,8" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="Сумма" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" Margin="4,8,10,8" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Rows -->
                    <ItemsControl x:Name="DetailsItems" Grid.Row="1" Margin="0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="0">
                                    <Border.ToolTip>
                                        <ToolTip MaxWidth="320">
                                            <TextBlock Text="{Binding Tooltip}"
                                                       TextWrapping="Wrap"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="10,8,4,8">
                                            <TextBlock Text="{Binding MaterialName}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Unit}" FontSize="9" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding QtyWithoutEconomy}" FontSize="11" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" Margin="4,8,10,8" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding QtyWithEconomy}" FontSize="11" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" Margin="4,8,10,8" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding QtySaved}" FontSize="11" Foreground="{DynamicResource EconomyGreen}" HorizontalAlignment="Right" Margin="4,8,10,8" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="4" Text="{Binding AmountSavedDisplay}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource EconomyGreen}" HorizontalAlignment="Right" Margin="4,8,10,8" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- Total savings -->
            <Border Grid.Row="3"
                    Background="{DynamicResource EconomyGreenLight}"
                    CornerRadius="6"
                    Padding="12,10"
                    Margin="24,14,24,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Общая экономия -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Общая экономия:"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource EconomyGreen}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalSaved"
                               Grid.Row="0" Grid.Column="1"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="{DynamicResource EconomyGreen}"
                               VerticalAlignment="Center"/>

                    <!-- Экономия на 1 откос -->
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Экономия на 1 откос:"
                               FontSize="11"
                               Foreground="{DynamicResource EconomyGreen}"
                               VerticalAlignment="Center"
                               Margin="0,4,0,0"/>
                    <TextBlock x:Name="TxtTotalSavedPerSlope"
                               Grid.Row="1" Grid.Column="1"
                               FontSize="11"
                               Foreground="{DynamicResource EconomyGreen}"
                               VerticalAlignment="Center"
                               Margin="0,4,0,0"/>
                </Grid>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="24,18,24,20">
                <Button Content="Закрыть"
                        Style="{DynamicResource GhostButton}"
                        MinWidth="90"
                        Padding="16,7"
                        FontSize="13"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
