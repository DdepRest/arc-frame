<Window x:Class="MosquitoNetCalculator.Controls.SendToFactoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отправить на завод"
        Width="640" Height="680"
        MinWidth="540" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="false"
        Icon="pack://application:,,,/Resources/app_icon.ico">
    <Window.Resources>
        <Storyboard x:Key="WindowOpenAnimation">
            <DoubleAnimation From="0.0" To="1.0" Duration="0:0:0.25"
                             Storyboard.TargetProperty="Opacity">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    <Border x:Name="RootBorder" Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource Border}" BorderThickness="1"
            CornerRadius="14" Margin="8" Opacity="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="3" Opacity="0.18"
                              Color="{DynamicResource ShadowColor}"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title bar -->
                <RowDefinition Height="*"/>      <!-- Main content -->
                <RowDefinition Height="Auto"/>   <!-- Footer buttons -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════ -->
            <!-- TITLE BAR with accent strip                        -->
            <!-- ══════════════════════════════════════════════════ -->
            <Border x:Name="TitleBar" Grid.Row="0"
                    Background="{DynamicResource HeaderBg}"
                    CornerRadius="14,14,0,0" Height="38"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Accent color strip -->
                    <Border Grid.Column="0" Width="4"
                            Background="{DynamicResource Accent}"
                            CornerRadius="14,0,0,0"
                            VerticalAlignment="Stretch"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="&#xE7B3;" FontSize="15"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Foreground="{DynamicResource Accent}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Отправить на завод"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" x:Name="BtnClose"
                            Width="40" Height="40" Background="Transparent"
                            BorderThickness="0" Cursor="Hand"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="Закрыть (Escape)"
                            Click="BtnClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="8" ClipToBounds="True">
                                    <Grid>
                                        <Border x:Name="HoverOverlay" Background="{DynamicResource Danger}" Opacity="0" CornerRadius="8"/>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="1" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════ -->
            <!-- SIDE-BY-SIDE CONTENT                               -->
            <!-- ══════════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Margin="20,16,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="245" MaxWidth="400"/>  <!-- Items list -->
                    <ColumnDefinition Width="16"/>   <!-- Gap -->
                    <ColumnDefinition Width="*"/>    <!-- Preview -->
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT COLUMN: Selection panel ─── -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Toolbar -->
                        <RowDefinition Height="*"/>     <!-- Items -->
                    </Grid.RowDefinitions>

                    <!-- Selection toolbar -->
                    <Border Grid.Row="0" Margin="0,0,0,10"
                            Background="{DynamicResource GhostBg}"
                            CornerRadius="8" Padding="10,10">
                        <StackPanel>
                            <!-- Counter chip -->
                            <Border Background="{DynamicResource AccentLight}"
                                    CornerRadius="5" Padding="8,4"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,8">
                                <TextBlock x:Name="CounterTxt"
                                           FontWeight="SemiBold" FontSize="11"
                                           Foreground="{DynamicResource Accent}"/>
                            </Border>
                            <!-- Toggle buttons -->
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnSelectAll"
                                        Content="Выбрать все"
                                        Click="BtnSelectAll_Click"
                                        Style="{DynamicResource GhostButton}"
                                        FontSize="11" FontWeight="Normal"
                                        Padding="10,4"
                                        Margin="0,0,6,0"/>
                                <Button x:Name="BtnDeselectAll"
                                        Content="Снять все"
                                        Click="BtnDeselectAll_Click"
                                        Style="{DynamicResource GhostButton}"
                                        FontSize="11" FontWeight="Normal"
                                        Padding="10,4"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Scrollable item lists -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Products section -->
                            <TextBlock x:Name="ProductsHeader"
                                       Text="Т О В А Р Ы"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="4,0,0,8"/>
                            <StackPanel x:Name="ProductsPanel" Margin="0,0,0,14"/>

                            <!-- Additional KPs section -->
                            <TextBlock x:Name="KpHeader"
                                       Text="Д О П О Л Н И Т Е Л Ь Н Ы Е   К П"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="4,0,0,8"/>
                            <StackPanel x:Name="KpPanel"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ─── RIGHT COLUMN: Preview ─── -->
                <Border Grid.Column="2" x:Name="PreviewBorder"
                        Background="{DynamicResource SectionBg}"
                        BorderBrush="{DynamicResource SubtleBorder}"
                        BorderThickness="1" CornerRadius="10"
                        ClipToBounds="True"
                        VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- Header -->
                            <RowDefinition Height="*"/>       <!-- Preview fills space -->
                            <RowDefinition Height="Auto"/>    <!-- Char count -->
                        </Grid.RowDefinitions>
                        <!-- Preview header -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource GhostBg}"
                                CornerRadius="10,10,0,0"
                                Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A1;" FontSize="14"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           Foreground="{DynamicResource Accent}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="Предпросмотр"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="LineCountTxt"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMuted}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <!-- Preview content -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalAlignment="Stretch">
                            <TextBlock x:Name="PreviewBox"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       FontFamily="Consolas, Cascadia Code, Courier New"
                                       Foreground="{DynamicResource TextPrimary}"
                                       Padding="14,10"
                                       ToolTip="Нажмите «Скопировать» чтобы скопировать текст"/>
                        </ScrollViewer>
                        <!-- Character count footer -->
                        <TextBlock x:Name="CharCountTxt"
                                   Grid.Row="2"
                                   Text="Символов: 0"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="11"
                                   Margin="6,6,0,0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════ -->
            <!-- FOOTER BUTTONS                                      -->
            <!-- ══════════════════════════════════════════════════ -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="20,14,20,16">
                <Button x:Name="BtnCloseFooter"
                        Content="Закрыть"
                        Style="{DynamicResource GhostButton}"
                        Click="BtnCloseFooter_Click"
                        IsCancel="True"
                        FontSize="12" Padding="16,7"
                        Margin="0,0,10,0"/>
                <Button x:Name="BtnCopy"
                        Style="{DynamicResource PrimaryButton}"
                        Click="BtnCopy_Click"
                        FontSize="13" Padding="18,7"
                        ToolTip="Копировать в буфер обмена (Ctrl+C)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C8;" FontSize="14"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Скопировать" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
