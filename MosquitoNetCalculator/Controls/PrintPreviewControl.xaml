<UserControl x:Class="MosquitoNetCalculator.Controls.PrintPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MosquitoNetCalculator.Controls">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- Левая боковая панель настроек печати             -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource SectionBg}">
            <StackPanel Margin="12,12">

                <!-- Принтер -->
                <TextBlock Text="ПРИНТЕР" Style="{DynamicResource SectionLabel}" Margin="0,0,0,4"/>
                <ComboBox x:Name="PrinterCombo" Margin="0,0,0,12"/>

                <!-- Копии -->
                <TextBlock Text="КОПИИ" Style="{DynamicResource SectionLabel}" Margin="0,0,0,4"/>
                <controls:NumericUpDownControl x:Name="CopiesControl" Height="32" Value="1"/>

                <!-- Collation -->
                <CheckBox x:Name="CollatedCheck" Content="Разбить по копиям"
                          IsChecked="True" Margin="0,10,0,0"
                          ToolTip="Включено: 1,2,3,1,2,3. Выключено: 1,1,2,2,3,3"/>

                <!-- Цветность -->
                <TextBlock Text="ЦВЕТ" Style="{DynamicResource SectionLabel}" Margin="0,12,0,4"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="ColorBtn" Content="Цветная" IsChecked="True"
                                 GroupName="ColorGroup" Margin="0,0,12,0"/>
                    <RadioButton x:Name="BwBtn" Content="Ч/б"
                                 GroupName="ColorGroup"/>
                </StackPanel>

                <!-- Страницы -->
                <TextBlock Text="СТРАНИЦЫ" Style="{DynamicResource SectionLabel}" Margin="0,12,0,4"/>
                <StackPanel x:Name="PageModePanel" Margin="0,0,0,4">
                    <RadioButton x:Name="PageModeAll" Content="Все страницы"
                                 GroupName="PageModeGroup" IsChecked="True"
                                 Checked="PageMode_Changed"/>
                    <RadioButton x:Name="PageModeRange" Content="Диапазон"
                                 GroupName="PageModeGroup"
                                 Checked="PageMode_Changed"
                                 Margin="0,4,0,0"/>
                    <RadioButton x:Name="PageModeSingle" Content="Одна страница"
                                 GroupName="PageModeGroup"
                                 Checked="PageMode_Changed"
                                 Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Поля диапазона -->
                <Border x:Name="RangeFieldsBorder" Margin="0,4,0,0"
                        Background="{DynamicResource Surface}"
                        BorderBrush="{DynamicResource Border}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,6"
                        Visibility="Collapsed">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="от" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,6,0" Width="20"/>
                            <controls:NumericUpDownControl x:Name="PageFromControl" Width="110"
                                                          ToolTip="Начальная страница диапазона"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="до" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,6,0" Width="20"/>
                            <controls:NumericUpDownControl x:Name="PageToControl" Width="110"
                                                          ToolTip="Конечная страница диапазона"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Поле одной страницы -->
                <Border x:Name="SinglePageBorder" Margin="0,4,0,0"
                        Background="{DynamicResource Surface}"
                        BorderBrush="{DynamicResource Border}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,6"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Страница" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,6,0"/>
                        <controls:NumericUpDownControl x:Name="SinglePageControl" Width="110"
                                                      ToolTip="Печатать только эту страницу"/>
                    </StackPanel>
                </Border>

                <!-- Диапазон-подсказка -->
                <TextBlock x:Name="RangeHint" Margin="0,8,0,0"
                           Foreground="{DynamicResource TextMuted}" FontSize="10"
                           TextWrapping="Wrap"/>

                <!-- Прогресс печати -->
                <ProgressBar x:Name="PrintProgressBar" Height="4" Margin="0,16,0,0"
                             Visibility="Collapsed" Minimum="0" Maximum="100"
                             Background="{DynamicResource TrackBg}"/>
                <TextBlock x:Name="ProgressText" Margin="0,4,0,0"
                           Visibility="Collapsed" FontSize="11"
                           Foreground="{DynamicResource TextMuted}"/>

                <!-- Кнопки -->
                <Button x:Name="PrintButton" Content="Печать" Margin="0,16,0,0"
                        Style="{DynamicResource PrimaryButton}"
                        Click="Print_Click" Height="36"/>
                <Button x:Name="SavePdfButton" Content="Сохранить PDF" Margin="0,8,0,0"
                        Style="{DynamicResource GhostButton}"
                        Click="SavePdf_Click"
                        Height="32"/>
                <Button Content="Закрыть" Margin="0,8,0,16"
                        Style="{DynamicResource GhostButton}"
                        Click="Close_Click" Height="32"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Разделитель -->
        <Border Grid.Column="1" Background="{DynamicResource Border}"/>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- Предпросмотр FlowDocument + кастомный Fluent-тулбар  -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="2" Background="{DynamicResource Surface}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Кастомный Fluent-тулбар — навигация страниц + зум -->
            <Border Grid.Row="0" Background="{DynamicResource HeaderBg}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"
                    Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <!-- Навигация по страницам -->
                    <Button x:Name="PrevPageBtn" Content="&lt;" Style="{DynamicResource GhostButton}"
                            Padding="6,2" Width="32" Height="28" Margin="0,0,4,0"
                            Click="PrevPage_Click" ToolTip="Предыдущая страница"/>
                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}"
                            BorderThickness="1" CornerRadius="4" Padding="10,0" Margin="0,0,4,0"
                            VerticalAlignment="Center" Height="28">
                        <TextBlock x:Name="PageIndicator" Text="1 / 1"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Button x:Name="NextPageBtn" Content="&gt;" Style="{DynamicResource GhostButton}"
                            Padding="6,2" Width="32" Height="28" Margin="0,0,12,0"
                            Click="NextPage_Click" ToolTip="Следующая страница"/>

                    <!-- Разделитель -->
                    <Border Width="1" Height="20" Background="{DynamicResource Border}"
                            VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <!-- Зум -->
                    <Button x:Name="ZoomOutBtn" Content="-" Style="{DynamicResource GhostButton}"
                            Padding="6,2" Width="32" Height="28" Margin="0,0,4,0"
                            Click="ZoomOut_Click" ToolTip="Уменьшить"/>
                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}"
                            BorderThickness="1" CornerRadius="4" Padding="10,0" Margin="0,0,4,0"
                            VerticalAlignment="Center" Height="28">
                        <TextBlock x:Name="ZoomLabel" Text="100 %"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Button x:Name="ZoomInBtn" Content="+" Style="{DynamicResource GhostButton}"
                            Padding="6,2" Width="32" Height="28" Margin="0,0,8,0"
                            Click="ZoomIn_Click" ToolTip="Увеличить"/>
                    <Button x:Name="ZoomResetBtn" Content="100%" Style="{DynamicResource GhostButton}"
                            Padding="8,2" Height="28" Margin="0,0,4,0"
                            Click="ZoomReset_Click" ToolTip="100% — натуральная величина"/>
                    <Button x:Name="ZoomFitPlusBtn" Content="Fit+20%" Style="{DynamicResource GhostButton}"
                            Padding="8,2" Height="28" Margin="0,0,4,0"
                            Click="ZoomFitPlus_Click" ToolTip="Вписать в окно + 20%"/>
                    <Button x:Name="ZoomFitBtn" Content="Fit" Style="{DynamicResource GhostButton}"
                            Padding="8,2" Height="28" Margin="0,0,8,0"
                            Click="ZoomFit_Click" ToolTip="Вписать в окно"/>
                </StackPanel>
            </Border>

            <!-- Предпросмотр документа -->
            <ScrollViewer x:Name="PreviewScroller" Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="PreviewScroller_PreviewMouseWheel"
                          Padding="24">
                <Grid x:Name="PreviewContainer"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="White"
                            BorderBrush="#777777" BorderThickness="2"
                            CornerRadius="2">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18" Color="#000000"/>
                        </Border.Effect>
                        <Grid>
                        <FlowDocumentPageViewer x:Name="DocumentReader"
                                                Loaded="DocumentReader_Loaded"
                                                Zoom="100"
                                                TextOptions.TextFormattingMode="Display"
                                                TextOptions.TextRenderingMode="ClearType"
                                                UseLayoutRounding="True"
                                                SnapsToDevicePixels="True"/>
                            <Border x:Name="DimmingOverlay"
                                    Background="#99FFFFFF"
                                    IsHitTestVisible="False"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="DimmingText"
                                           Text="Стр. X не входит в диапазон печати"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontSize="24"
                                           Foreground="#666666"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Padding="40"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
