<UserControl x:Class="MosquitoNetCalculator.Controls.OrdersHistoryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource AppBg}" Margin="0" Opacity="0">
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Info panel -->
        <Border Grid.Row="0" Background="{DynamicResource Surface}" CornerRadius="10"
                Padding="14,9" Margin="8,8,8,6"
                BorderBrush="{DynamicResource Border}" BorderThickness="1"
                Style="{DynamicResource Card}"
                ClipToBounds="True">
            <Border.Clip>
                <RectangleGeometry Rect="0,0,10000,10000" RadiusX="10" RadiusY="10"/>
            </Border.Clip>
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ЗАКАЗЫ" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <Border Background="{DynamicResource ChipBg}" CornerRadius="10"
                            Padding="10,3" Margin="0,0,14,0">
                        <TextBlock x:Name="TxtOrdersCount" Text="Заказов: 0"
                                   FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Accent}"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{DynamicResource GhostButton}"
                            Click="BtnImportOrders_Click" Margin="0,0,8,0"
                            ToolTip="Импортировать заказы из файла">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE8B5;"/>
                            <TextBlock Text="Импорт"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource GhostButton}"
                            Click="BtnExportOrders_Click" Margin="0,0,8,0"
                            ToolTip="Экспортировать заказы в файл">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE898;"/>
                            <TextBlock Text="Экспорт"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource GhostButton}"
                            Click="BtnRefreshOrders_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE72C;"/>
                            <TextBlock Text="Обновить"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search bar -->
        <Border Grid.Row="1" Margin="8,0,8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xE721;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="14" Foreground="{DynamicResource TextMuted}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="TxtSearchOrders" Grid.Column="1"
                         Style="{DynamicResource QuickInput}"
                         TextChanged="TxtSearchOrders_TextChanged"
                         ToolTip="Фильтр по № КП, адресу или телефону"/>
                <Button x:Name="BtnClearOrdersSearch" Grid.Column="2"
                        Style="{DynamicResource GhostButton}"
                        Content="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                        FontSize="10" Padding="4,2" Margin="4,0,0,0" Cursor="Hand"
                        Visibility="Collapsed"
                        Click="BtnClearOrdersSearch_Click"
                        ToolTip="Очистить поиск"/>
            </Grid>
        </Border>

        <!-- Orders table -->
        <Border Grid.Row="2" Background="{DynamicResource Surface}" CornerRadius="10"
                BorderBrush="{DynamicResource Border}" BorderThickness="1" Margin="8,0,8,8"
                Style="{DynamicResource Card}"
                ClipToBounds="True">
            <Border.Clip>
                <RectangleGeometry Rect="0,0,10000,10000" RadiusX="10" RadiusY="10"/>
            </Border.Clip>
            <Grid>
                <DataGrid x:Name="OrdersList"
                      AutoGenerateColumns="False"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0" Background="Transparent"
                      AlternationCount="2"
                      RowBackground="{DynamicResource Surface}"
                      AlternatingRowBackground="{DynamicResource RowAlt}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      Sorting="OrdersList_Sorting">
                <DataGrid.ContextMenu>
                    <ContextMenu Style="{StaticResource {x:Type ContextMenu}}">
                        <MenuItem x:Name="CtxOpenMenu" Header="Открыть заказ" Click="CtxOpen_Click" Style="{StaticResource {x:Type MenuItem}}"/>
                        <MenuItem x:Name="CtxStatusMenu" Header="Изменить статус..." IsEnabled="False" Click="CtxStatus_Click" Style="{StaticResource {x:Type MenuItem}}"/>
                        <MenuItem x:Name="CtxExportMenu" Header="Экспорт заказа" IsEnabled="False" Click="CtxExport_Click" Style="{StaticResource {x:Type MenuItem}}"/>
                        <Separator Style="{StaticResource {x:Type Separator}}"/>
                        <MenuItem x:Name="CtxCopyMenu" Header="Копировать" IsEnabled="False" Click="CtxCopy_Click" Style="{StaticResource {x:Type MenuItem}}"/>
                        <Separator Style="{StaticResource {x:Type Separator}}"/>
                        <MenuItem x:Name="CtxDeleteMenu" Header="Удалить заказ" IsEnabled="False" Click="CtxDelete_Click" Foreground="{DynamicResource Danger}" Style="{StaticResource {x:Type MenuItem}}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.RowStyle>
                    <StaticResource ResourceKey="OrdersRow"/>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№ КП"
                                        Binding="{Binding ContractNumber}"
                                        SortMemberPath="ContractNumberSortKey"
                                        Width="Auto" MinWidth="60"/>

                    <DataGridTextColumn Header="Адрес"
                                        Binding="{Binding ClientAddress}"
                                        Width="*" MinWidth="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Телефон"
                                        Binding="{Binding ClientPhone}"
                                        Width="Auto" MinWidth="100"/>

                    <DataGridTextColumn Header="Дата"
                                        Binding="{Binding ContractDate, StringFormat='dd.MM.yyyy'}"
                                        Width="Auto" MinWidth="80"/>

                    <DataGridTextColumn Header="Сумма, руб."
                                        Binding="{Binding TotalAmount, Converter={StaticResource MoneyConv}}"
                                        Width="Auto" MinWidth="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Статус"
                                            Width="Auto" MinWidth="100"
                                            SortMemberPath="StatusRank">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,3"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{Binding Status, Converter={StaticResource StatusToBadgeBg}}">
                                    <TextBlock Text="{Binding Status}"
                                               FontSize="11" FontWeight="Medium"
                                               HorizontalAlignment="Center"
                                               Foreground="{Binding Status, Converter={StaticResource StatusToBadgeFg}}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Обновлено"
                                        Binding="{Binding UpdatedAt, StringFormat='dd.MM.yy HH:mm'}"
                                        Width="Auto" MinWidth="110"/>
                </DataGrid.Columns>
            </DataGrid>

                <!-- Empty state — Fluent illustration with action button -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            x:Name="OrdersEmptyState"
                            Visibility="{Binding IsEmpty, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,40">
                    <TextBlock Text="" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="60"
                               Foreground="{DynamicResource TextMuted}"
                               Opacity="0.30"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Заказов пока нет"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center" Margin="0,10,0,2"/>
                    <TextBlock Text="Создайте первый заказ на вкладке «Расчёт», заполните позиции и сохраните"
                               FontSize="11"
                               Foreground="{DynamicResource TextMuted}"
                               Opacity="0.75"
                               HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <Button Style="{DynamicResource GhostButton}"
                            HorizontalAlignment="Center"
                            Click="BtnGoToCalculation_Click"
                            ToolTip="Вернуться к расчёту (Ctrl+1)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource FluentIconButton}" Text="&#xE1D0;"/>
                            <TextBlock Text="Перейти к расчёту"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
