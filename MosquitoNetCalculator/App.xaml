<Application x:Class="MosquitoNetCalculator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MosquitoNetCalculator.Converters"
             ShutdownMode="OnExplicitShutdown"
             >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Brushes first: styles reference brushes via DynamicResource —
                     they must be loaded before styles, especially ShadowColor
                     used in the Card style's DropShadowEffect (a Freezable). -->
                <ResourceDictionary Source="Themes/Brushes.xaml"/>
                <!-- Focus visual: loaded early so all subsequent style dictionaries
                     can reference FluentFocusVisual via StaticResource. -->
                <ResourceDictionary Source="Themes/FocusVisualStyles.xaml"/>
                <!-- Base/dependency-free styles -->
                <ResourceDictionary Source="Themes/CardStyles.xaml"/>
                <ResourceDictionary Source="Themes/FontStyles.xaml"/>
                <ResourceDictionary Source="Themes/TabStyles.xaml"/>
                <ResourceDictionary Source="Themes/ButtonStyles.xaml"/>
                <ResourceDictionary Source="Themes/InputStyles.xaml"/>
                <ResourceDictionary Source="Themes/DataGridStyles.xaml"/>
                <!-- п.2: Fluent RadioButton style (implicit, без x:Key → подхватывается глобально). -->
                <ResourceDictionary Source="Themes/InputStyles.RadioButton.xaml"/>
                <ResourceDictionary Source="Themes/ScrollViewerStyles.xaml"/>
                <ResourceDictionary Source="Themes/ContextMenuStyles.xaml"/>
                <ResourceDictionary Source="Themes/MiscStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- CONVERTERS — used via StaticResource, never change     -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <conv:DimensionConverter x:Key="DimConv"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:StatusToBadgeBackgroundConverter x:Key="StatusToBadgeBg"/>
            <conv:StatusToBadgeForegroundConverter x:Key="StatusToBadgeFg"/>
            <conv:MoneyConverter x:Key="MoneyConv"/>
            <conv:RussianDateConverter x:Key="RussianDateConv"/>
            <conv:UpdateTypeToBrushConverter x:Key="UpdateTypeBrush"/>
            <conv:UpdateTypeToIconConverter x:Key="UpdateTypeIcon"/>
            <conv:InverseBoolConverter x:Key="InverseBool"/>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- GLOBAL TOOLTIP STYLE — applied to all tooltips without    -->
            <!-- explicit Style. Uses theme brushes so tooltip follows    -->
            <!-- light/dark theme. Tooltips with explicit Style override.  -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Style TargetType="ToolTip">
                <Setter Property="Background" Value="{DynamicResource Surface}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="HasDropShadow" Value="False"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
